  "plan": {
    "question_intent": "Calculate the total sales revenue for products in the 'Beverages' category that were shipped in 1997, considering discounts.",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.categoryname, o.orderid, o.shippeddate, od.unitprice, od.quantity, od.discount, (od.unitprice * od.quantity * (1 - od.discount)) AS revenue\nFROM orders o\nJOIN \"order details\" od ON o.orderid = od.orderid\nJOIN products p ON od.productid = p.productid\nJOIN categories c ON p.categoryid = c.categoryid\nWHERE c.categoryname = 'Beverages' AND strftime('%Y', o.shippeddate) = '1997'\nGROUP BY c.categoryname, o.orderid, o.shippeddate, od.unitprice, od.quantity, od.discount\nORDER BY revenue DESC",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.categoryname, o.orderid, o.shippeddate, od.unitprice, od.quantity, od.discount, (od.unitprice * od.quantity * (1 - od.discount)) AS revenue",
        "from_clause": "FROM orders o",
        "join_clauses": [
          "JOIN \"order details\" od ON o.orderid = od.orderid",
          "JOIN products p ON od.productid = p.productid",
          "JOIN categories c ON p.categoryid = c.categoryid"
        ],
        "where_clauses": [
          "c.categoryname = 'Beverages'",
          "strftime('%Y', o.shippeddate) = '1997'"
        ],
        "group_by_clause": "GROUP BY c.categoryname, o.orderid, o.shippeddate, od.unitprice, od.quantity, od.discount",
        "having_clauses": [],
        "notes": "This block retrieves the category name, order ID, shipped date, unit price, quantity, discount, and calculated revenue for each order detail of products in the 'Beverages' category shipped in 1997."
      },
