  "plan": {
    "question_intent": "average sales per product in the Beverages category shipped to London in 1997",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT p.productid, p.productname, od.quantity, od.unitprice, (od.quantity * od.unitprice) AS sales_amount FROM products p JOIN \"order details\" od ON p.productid = od.productid JOIN orders o ON od.orderid = o.orderid JOIN categories c ON p.categoryid = c.categoryid WHERE c.categoryname = 'Beverages' AND o.shipcity = 'London' AND strftime('%Y', o.shippeddate) = '1997'",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT p.productid, p.productname, SUM(od.quantity * od.unitprice) AS sales_amount",
        "from_clause": "FROM products p",
        "join_clauses": [
          "JOIN \"order details\" od ON p.productid = od.productid",
          "JOIN orders o ON od.orderid = o.orderid",
          "JOIN categories c ON p.categoryid = c.categoryid"
        ],
        "where_clauses": [
          "c.categoryname = 'Beverages'",
          "o.shipcity = 'London'",
          "strftime('%Y', o.shippeddate) = '1997'"
        ],
        "group_by_clause": "GROUP BY p.productid, p.productname",
        "having_clauses": [],
        "notes": "sales amount per product in the Beverages category shipped to London in 1997"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.sales_amount) AS average_sales_per_product",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "average sales per product in the Beverages category shipped to London in 1997"
      }
    ]
  },
