  "plan": {
    "question_intent": "Calculate the total sales revenue for orders shipped in 1997 from the 'Beverages' category, grouped by the shipper company name and having a revenue greater than 100.",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.shippername, leaf_1.revenue FROM (SELECT s.companyname AS shippername, SUM(od.quantity * od.unitprice) AS revenue FROM orders AS o JOIN \"order details\" AS od ON o.orderid = od.orderid JOIN products AS p ON od.productid = p.productid JOIN categories AS c ON p.categoryid = c.categoryid JOIN shippers AS s ON o.shipvia = s.shipperid WHERE c.categoryname = 'Beverages' AND strftime('%Y', o.shippeddate) = '1997' GROUP BY s.companyname HAVING revenue > 100) AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT s.companyname AS shippername, SUM(od.quantity * od.unitprice) AS revenue",
        "from_clause": "FROM orders AS o",
        "join_clauses": [
          "JOIN \"order details\" AS od ON o.orderid = od.orderid",
          "JOIN products AS p ON od.productid = p.productid",
          "JOIN categories AS c ON p.categoryid = c.categoryid",
          "JOIN shippers AS s ON o.shipvia = s.shipperid"
        ],
        "where_clauses": [
          "c.categoryname = 'Beverages'",
          "strftime('%Y', o.shippeddate) = '1997'"
        ],
        "group_by_clause": "GROUP BY s.companyname",
        "having_clauses": [
          "revenue > 100"
        ],
        "notes": "This block calculates the total sales revenue for each shipper company name from the 'Beverages' category, shipped in 1997, with a revenue greater than 100."
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(leaf_1.revenue) AS total_sales_revenue",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "This block calculates the total sales revenue for all shippers from the 'Beverages' category, shipped in 1997, with a revenue greater than 100."
      }
    ]
  },
