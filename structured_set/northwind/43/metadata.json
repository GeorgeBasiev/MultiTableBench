          "stage": "final",
          "sql": "SELECT c.customerid, c.companyname, c.city, c.country, o.orderid, o.orderdate, p.productname, od.quantity, od.unitprice, (od.quantity * od.unitprice) AS line_total\nFROM customers AS c\nJOIN orders AS o ON c.customerid = o.customerid\nJOIN \"order details\" AS od ON o.orderid = od.orderid\nJOIN products AS p ON od.productid = p.productid\nJOIN categories AS cat ON p.categoryid = cat.categoryid\nWHERE (c.region = 'Eastern' OR c.region IS NULL) AND (cat.categoryname = 'Beverages') AND (strftime('%Y', o.orderdate) = '1997')",
