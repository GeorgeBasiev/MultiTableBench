  "plan": {
    "question_intent": "Calculate the total revenue generated by customers in the Eastern region who purchased products from the Beverages category in 1997",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.customerid, c.companyname, c.city, c.country, o.orderid, o.orderdate, p.productname, od.quantity, od.unitprice, (od.quantity * od.unitprice) AS line_total FROM customers AS c JOIN orders AS o ON c.customerid = o.customerid JOIN order_details AS od ON o.orderid = od.orderid JOIN products AS p ON od.productid = p.productid JOIN categories AS cat ON p.categoryid = cat.categoryid WHERE c.region = 'Eastern' AND cat.categoryname = 'Beverages' AND strftime('%Y', o.orderdate) = '1997' ORDER BY c.customerid, o.orderid, p.productid",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.customerid, c.companyname, c.city, c.country, o.orderid, o.orderdate, p.productname, od.quantity, od.unitprice, (od.quantity * od.unitprice) AS line_total",
        "from_clause": "FROM customers AS c",
        "join_clauses": [
          "JOIN orders AS o ON c.customerid = o.customerid",
          "JOIN order_details AS od ON o.orderid = od.orderid",
          "JOIN products AS p ON od.productid = p.productid",
          "JOIN categories AS cat ON p.categoryid = cat.categoryid"
        ],
        "where_clauses": [
          "c.region = 'Eastern'",
          "cat.categoryname = 'Beverages'",
          "strftime('%Y', o.orderdate) = '1997'"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "This block retrieves customer, order, and product details for customers in the Eastern region who purchased Beverages products in 1997"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(leaf_1.line_total) AS total_revenue",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
