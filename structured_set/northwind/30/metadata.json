        {
          "stage": "having",
          "clause": "AVG(od.quantity * od.unitprice) > 100",
          "sql": "SELECT c.customerid, AVG(od.quantity * od.unitprice) AS avg_order_value\nFROM customers AS c\nJOIN orders AS o ON c.customerid = o.customerid\nJOIN \"order details\" AS od ON o.orderid = od.orderid\nJOIN products AS p ON od.productid = p.productid\nJOIN categories AS cat ON p.categoryid = cat.categoryid\nWHERE (c.region IS NOT NULL) AND (cat.categoryname = 'Beverages') AND (strftime('%Y', o.orderdate) = '1997')\nGROUP BY c.customerid\nHAVING (AVG(od.quantity * od.unitprice) > 100)",
