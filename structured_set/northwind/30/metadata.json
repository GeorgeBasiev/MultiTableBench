  "plan": {
    "question_intent": "average order value for customers in the Eastern region who ordered products from the Beverages category in 1997",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.customerid, c.companyname, o.orderid, o.orderdate, p.productname, cat.categoryname, od.quantity, od.unitprice, (od.quantity * od.unitprice) AS line_total FROM customers AS c JOIN orders AS o ON c.customerid = o.customerid JOIN order_details AS od ON o.orderid = od.orderid JOIN products AS p ON od.productid = p.productid JOIN categories AS cat ON p.categoryid = cat.categoryid WHERE c.region = 'Eastern' AND cat.categoryname = 'Beverages' AND strftime('%Y', o.orderdate) = '1997'",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.customerid, AVG(od.quantity * od.unitprice) AS avg_order_value",
        "from_clause": "FROM customers AS c",
        "join_clauses": [
          "JOIN orders AS o ON c.customerid = o.customerid",
          "JOIN order_details AS od ON o.orderid = od.orderid",
          "JOIN products AS p ON od.productid = p.productid",
          "JOIN categories AS cat ON p.categoryid = cat.categoryid"
        ],
        "where_clauses": [
          "c.region = 'Eastern'",
          "cat.categoryname = 'Beverages'",
          "strftime('%Y', o.orderdate) = '1997'"
        ],
        "group_by_clause": "GROUP BY c.customerid",
        "having_clauses": [
          "AVG(od.quantity * od.unitprice) > 100"
        ],
        "notes": "average order value for customers in the Eastern region who ordered Beverages products in 1997"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.avg_order_value)",
