  "plan": {
    "question_intent": "average total sales amount per customer for customers with more than 10 orders in the year 1997 who ordered products from the 'Beverages' category",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.customerid, c.companyname, COUNT(o.orderid) AS order_count, SUM(od.unitprice * od.quantity) AS total_sales FROM customers c JOIN orders o ON c.customerid = o.customerid JOIN order details od ON o.orderid = od.orderid JOIN products p ON od.productid = p.productid JOIN categories cat ON p.categoryid = cat.categoryid WHERE strftime('%Y', o.orderdate) = '1997' AND cat.categoryname = 'Beverages' GROUP BY c.customerid, c.companyname HAVING COUNT(o.orderid) > 10",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.customerid, c.companyname, COUNT(o.orderid) AS order_count, SUM(od.unitprice * od.quantity) AS total_sales",
        "from_clause": "FROM customers c",
        "join_clauses": [
          "JOIN orders o ON c.customerid = o.customerid",
          "JOIN order details od ON o.orderid = od.orderid",
          "JOIN products p ON od.productid = p.productid",
          "JOIN categories cat ON p.categoryid = cat.categoryid"
        ],
        "where_clauses": [
          "strftime('%Y', o.orderdate) = '1997'",
          "cat.categoryname = 'Beverages'"
        ],
        "group_by_clause": "GROUP BY c.customerid, c.companyname",
        "having_clauses": [
          "COUNT(o.orderid) > 10"
        ],
        "notes": "total sales and order count per customer for customers with more than 10 orders in 1997 who ordered Beverages"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.total_sales)",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
