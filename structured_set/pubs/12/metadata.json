  "plan": {
    "question_intent": "calculate the total sales revenue for stores in California",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT s.stor_name, s.city, s.state, SUM(t.price * s2.qty) AS total_revenue FROM stores AS s JOIN sales AS s2 ON s.stor_id = s2.stor_id JOIN titles AS t ON s2.title_id = t.title_id WHERE s.state = 'CA' GROUP BY s.stor_name, s.city, s.state",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT s.stor_id, s.stor_name, s.city, s.state, t.title_id, s2.qty, t.price",
        "from_clause": "FROM stores AS s",
        "join_clauses": [
          "JOIN sales AS s2 ON s.stor_id = s2.stor_id",
          "JOIN titles AS t ON s2.title_id = t.title_id"
        ],
        "where_clauses": [
          "s.state = 'CA'"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "retrieves store details, sales quantities, and title prices for stores in California"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(leaf_1.price * leaf_1.qty) AS total_sales_revenue",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "calculates the total sales revenue for stores in California"
      }
