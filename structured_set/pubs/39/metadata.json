  "plan": {
    "question_intent": "What is the total revenue generated from sales of titles where the author's royalty percentage is between 30% and 50%?",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT s.ord_num, s.ord_date, s.qty, t.title, t.price, ta.royaltyper FROM sales s JOIN titles t ON s.title_id = t.title_id JOIN titleauthor ta ON t.title_id = ta.title_id WHERE ta.royaltyper BETWEEN 30 AND 50 ORDER BY s.ord_num",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT s.qty, t.price, ta.royaltyper",
        "from_clause": "FROM sales s",
        "join_clauses": [
          "JOIN titles t ON s.title_id = t.title_id",
          "JOIN titleauthor ta ON t.title_id = ta.title_id"
        ],
        "where_clauses": [
          "ta.royaltyper BETWEEN 30 AND 50"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "This block retrieves the quantity, price, and royalty percentage for each sale of a title where the author's royalty percentage is between 30% and 50%."
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(leaf_1.qty * leaf_1.price * (leaf_1.royaltyper / 100)) AS total_revenue",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "This block calculates the total revenue generated from sales of titles where the author's royalty percentage is between 30% and 50%."
      }
    ]
  },
