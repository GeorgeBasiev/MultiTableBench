    "question_intent": "total revenue from sales of titles published by Algodata Infosystems",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT t.title_id, t.title, s.qty, t.price, ta.royaltyper, (s.qty * t.price) AS revenue\nFROM titles AS t\nJOIN sales AS s ON t.title_id = s.title_id\nJOIN titleauthor AS ta ON t.title_id = ta.title_id\nWHERE t.pub_id = '1389'",
