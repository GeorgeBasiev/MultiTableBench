  "plan": {
    "question_intent": "Find the job description of the employee who made the highest royalty payment for a book published by Algodata Infosystems",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT e.emp_id, e.fname, e.lname, j.job_desc, t.title, t.pub_id, p.pub_name, r.lorange, r.hirange, r.royalty, s.qty, (r.royalty * s.qty / 100) AS royalty_payment FROM employee AS e JOIN jobs AS j ON e.job_id = j.job_id JOIN titles AS t ON e.pub_id = t.pub_id JOIN roysched AS r ON t.title_id = r.title_id JOIN sales AS s ON t.title_id = s.title_id WHERE t.pub_id = 1389 ORDER BY royalty_payment DESC LIMIT 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT e.emp_id, e.job_id, t.title_id, r.royalty, s.qty, (r.royalty * s.qty / 100) AS royalty_payment",
        "from_clause": "FROM employee AS e",
        "join_clauses": [
          "JOIN titles AS t ON e.pub_id = t.pub_id",
          "JOIN roysched AS r ON t.title_id = r.title_id",
          "JOIN sales AS s ON t.title_id = s.title_id"
        ],
        "where_clauses": [
          "t.pub_id = 1389"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "This block calculates the royalty payment for each employee based on the sales of books published by Algodata Infosystems"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT j.job_desc",
        "from_clause": "FROM jobs AS j",
        "join_clauses": [
          "JOIN (SELECT e.emp_id, e.job_id FROM {{leaf_1}} AS leaf_1 ORDER BY royalty_payment DESC LIMIT 1) AS emp ON j.job_id = emp.job_id"
        ],
        "where_clauses": [],
        "group_by_clause": "",
