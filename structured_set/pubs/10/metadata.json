  "plan": {
    "question_intent": "average royalty percentage for authors who have written books published by publishers in California",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT a.au_id, a.au_lname, a.au_fname, t.title, p.pub_name, p.city, p.state, ta.royaltyper\nFROM authors a\nJOIN titleauthor ta ON a.au_id = ta.au_id\nJOIN titles t ON ta.title_id = t.title_id\nJOIN publishers p ON t.pub_id = p.pub_id\nWHERE p.state = 'CA'",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT a.au_id, a.au_lname, a.au_fname, ta.royaltyper",
        "from_clause": "FROM authors a",
        "join_clauses": [
          "JOIN titleauthor ta ON a.au_id = ta.au_id",
          "JOIN titles t ON ta.title_id = t.title_id",
          "JOIN publishers p ON t.pub_id = p.pub_id"
        ],
        "where_clauses": [
          "p.state = 'CA'"
        ],
        "group_by_clause": "GROUP BY a.au_id, a.au_lname, a.au_fname, ta.royaltyper",
        "having_clauses": [
          "COUNT(DISTINCT t.title_id) > 0"
        ],
        "notes": "authors with their royalty percentages and at least one title published by a CA publisher"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.royaltyper)",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
