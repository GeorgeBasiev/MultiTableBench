  "plan": {
    "question_intent": "average number of authors per book published by Algodata Infosystems",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.title_id, leaf_1.author_count FROM (SELECT t.title_id, COUNT(DISTINCT ta.au_id) AS author_count FROM titles t JOIN titleauthor ta ON t.title_id = ta.title_id JOIN publishers pub ON t.pub_id = pub.pub_id WHERE pub.pub_id = '1389' GROUP BY t.title_id) AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT t.title_id, COUNT(DISTINCT ta.au_id) AS author_count",
        "from_clause": "FROM titles t",
        "join_clauses": [
          "JOIN titleauthor ta ON t.title_id = ta.title_id",
          "JOIN publishers pub ON t.pub_id = pub.pub_id"
        ],
        "where_clauses": [
          "pub.pub_id = '1389'"
        ],
        "group_by_clause": "GROUP BY t.title_id",
        "having_clauses": [],
        "notes": "counts the number of distinct authors for each book published by Algodata Infosystems"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.author_count)",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
