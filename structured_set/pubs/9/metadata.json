  "plan": {
    "question_intent": "Calculate the total revenue generated from business titles sold in California stores",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT s.stor_id, s.stor_name, t.title_id, t.title, sa.qty, t.price, t.royalty, ta.royaltyper, (sa.qty * t.price * t.royalty / 100 * ta.royaltyper / 100) AS revenue FROM stores s JOIN sales sa ON s.stor_id = sa.stor_id JOIN titles t ON sa.title_id = t.title_id JOIN titleauthor ta ON t.title_id = ta.title_id WHERE t.type = 'business' AND s.state = 'CA'",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT s.stor_id, t.title_id, sa.qty, t.price, t.royalty, ta.royaltyper, (sa.qty * t.price * t.royalty / 100 * ta.royaltyper / 100) AS revenue",
        "from_clause": "FROM stores s",
        "join_clauses": [
          "JOIN sales sa ON s.stor_id = sa.stor_id",
          "JOIN titles t ON sa.title_id = t.title_id",
          "JOIN titleauthor ta ON t.title_id = ta.title_id"
        ],
        "where_clauses": [
          "(t.type = 'business')",
          "(s.state = 'CA')"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "This block calculates the revenue for each sale of a business title in a California store"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(revenue) AS total_revenue",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "This block calculates the total revenue generated from business titles sold in California stores"
      }
    ]
  },
