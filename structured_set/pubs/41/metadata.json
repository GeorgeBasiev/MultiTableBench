  "plan": {
    "question_intent": "get the city of the publisher of the title with the most sales",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT t.title_id, t.title, t.pub_id, p.pub_name, p.city, SUM(s.qty) AS total_sales FROM titles t JOIN sales s ON t.title_id = s.title_id JOIN publishers p ON t.pub_id = p.pub_id GROUP BY t.title_id, t.title, t.pub_id, p.pub_name, p.city ORDER BY total_sales DESC",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT t.title_id, t.pub_id, SUM(s.qty) AS total_sales",
        "from_clause": "FROM titles t",
        "join_clauses": [
          "JOIN sales s ON t.title_id = s.title_id"
        ],
        "where_clauses": [],
        "group_by_clause": "GROUP BY t.title_id, t.pub_id",
        "having_clauses": [],
        "notes": "returns the total sales for each title and its corresponding publisher"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT p.city",
        "from_clause": "FROM ({{leaf_1}}) AS leaf_1",
        "join_clauses": [
          "JOIN publishers p ON leaf_1.pub_id = p.pub_id"
        ],
        "where_clauses": [
          "leaf_1.total_sales = (SELECT MAX(total_sales) FROM ({{leaf_1}}) AS leaf_1)"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "final scalar block"
      }
    ]
  },
