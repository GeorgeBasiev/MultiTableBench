  "plan": {
    "question_intent": "Total revenue generated from sales of titles in California stores",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT a.au_id, a.au_lname, a.au_fname, s.stor_id, s.ord_num, s.ord_date, s.qty, s.payterms, t.title_id, t.title, t.price, ta.royaltyper, (s.qty * t.price) AS revenue FROM authors AS a JOIN titleauthor AS ta ON a.au_id = ta.au_id JOIN titles AS t ON ta.title_id = t.title_id JOIN sales AS s ON t.title_id = s.title_id JOIN stores AS st ON s.stor_id = st.stor_id WHERE (st.state = 'CA')",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT s.stor_id, s.ord_num, s.ord_date, s.qty, s.payterms, t.title_id, t.title, t.price, ta.royaltyper, (s.qty * t.price) AS revenue",
        "from_clause": "FROM sales AS s",
        "join_clauses": [
          "JOIN titles AS t ON s.title_id = t.title_id",
          "JOIN titleauthor AS ta ON t.title_id = ta.title_id"
        ],
        "where_clauses": [
          "s.stor_id IN (SELECT stor_id FROM stores WHERE state = 'CA')"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Sales records with title details for California stores"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(revenue) AS total_revenue",
        "from_clause": "FROM (SELECT s.stor_id, s.ord_num, s.ord_date, s.qty, s.payterms, t.title_id, t.title, t.price, ta.royaltyper, (s.qty * t.price) AS revenue FROM sales AS s JOIN titles AS t ON s.title_id = t.title_id JOIN titleauthor AS ta ON t.title_id = ta.title_id WHERE s.stor_id IN (SELECT stor_id FROM stores WHERE state = 'CA')) AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Total revenue from sales in California stores"
      }
    ]
