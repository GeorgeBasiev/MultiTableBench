  "plan": {
    "question_intent": "average advance per employee by job level",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT e.job_lvl, e.fname, e.lname, j.job_desc, AVG(t.advance) AS avg_advance FROM employee e JOIN jobs j ON e.job_lvl BETWEEN j.min_lvl AND j.max_lvl JOIN titles t ON e.pub_id = t.pub_id GROUP BY e.job_lvl, e.fname, e.lname, j.job_desc ORDER BY e.job_lvl, e.fname, e.lname",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT e.job_lvl, e.fname, e.lname, j.job_desc, AVG(t.advance) AS avg_advance",
        "from_clause": "FROM employee e",
        "join_clauses": [
          "JOIN jobs j ON e.job_lvl BETWEEN j.min_lvl AND j.max_lvl",
          "JOIN titles t ON e.pub_id = t.pub_id"
        ],
        "where_clauses": [],
        "group_by_clause": "GROUP BY e.job_lvl, e.fname, e.lname, j.job_desc",
