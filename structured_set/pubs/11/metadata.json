  "plan": {
    "question_intent": "Find the city of the publisher that has the highest job level employee with the job description 'Business Operations Manager'",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT e.emp_id, e.fname, e.lname, e.job_lvl, p.city\nFROM employee e\nJOIN jobs j ON e.job_id = j.job_id\nJOIN publishers p ON e.pub_id = p.pub_id\nWHERE j.job_desc = 'Business Operations Manager'\nORDER BY e.job_lvl DESC\nLIMIT 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT e.pub_id, e.job_lvl",
        "from_clause": "FROM employee e",
        "join_clauses": [
          "JOIN jobs j ON e.job_id = j.job_id"
        ],
        "where_clauses": [
          "j.job_desc = 'Business Operations Manager'"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "This block returns the pub_id and job_lvl for employees with the job description 'Business Operations Manager'"
      },
      {
        "name": "leaf_2",
        "role": "leaf",
        "select_clause": "SELECT MAX(job_lvl) AS max_job_lvl",
        "from_clause": "FROM {{leaf_1}}",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "This block returns the maximum job level from the leaf_1 block"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT p.city",
        "from_clause": "FROM publishers p",
        "join_clauses": [
          "JOIN (SELECT e.pub_id FROM employee e JOIN jobs j ON e.job_id = j.job_id WHERE j.job_desc = 'Business Operations Manager' AND e.job_lvl = (SELECT MAX(job_lvl) FROM (SELECT e.pub_id, e.job_lvl FROM employee e JOIN jobs j ON e.job_id = j.job_id WHERE j.job_desc = 'Business Operations Manager'))) AS e ON p.pub_id = e.pub_id"
        ],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "This block returns the city of the publisher with the highest job level employee with the job description 'Business Operations Manager'"
      }
    ]
