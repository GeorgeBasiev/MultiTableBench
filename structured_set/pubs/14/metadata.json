  "plan": {
    "question_intent": "calculate total revenue from sales of titles published by Algodata Infosystems",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.title_id, leaf_1.title, leaf_1.price, leaf_1.qty, leaf_1.discount, leaf_1.stor_id, leaf_1.stor_name, leaf_1.city, leaf_1.state\nFROM (SELECT titles.title_id, titles.title, titles.price, sales.qty, discounts.discount, sales.stor_id, stores.stor_name, stores.city, stores.state\nFROM titles\nJOIN sales ON titles.title_id = sales.title_id\nJOIN stores ON sales.stor_id = stores.stor_id\nLEFT JOIN discounts ON sales.stor_id = discounts.stor_id\nWHERE titles.pub_id = 1389) AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT titles.title_id, titles.title, titles.price, sales.qty, discounts.discount, sales.stor_id, stores.stor_name, stores.city, stores.state",
        "from_clause": "FROM titles",
        "join_clauses": [
          "JOIN sales ON titles.title_id = sales.title_id",
          "JOIN stores ON sales.stor_id = stores.stor_id",
          "LEFT JOIN discounts ON sales.stor_id = discounts.stor_id"
        ],
        "where_clauses": [
          "titles.pub_id = 1389"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "retrieve title details, sales quantities, discounts, and store information for titles published by Algodata Infosystems"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM((leaf_1.price * leaf_1.qty) * (1 - COALESCE(leaf_1.discount, 0) / 100)) AS total_revenue",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "calculate total revenue from sales of titles published by Algodata Infosystems, applying discounts where applicable"
      }
    ]
  },
