  "plan": {
    "question_intent": "total revenue generated from sales of titles published by Algodata Infosystems in California, where the sales were made in stores located in California",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.stor_id, leaf_1.ord_num, leaf_1.ord_date, leaf_1.qty, leaf_1.payterms, leaf_1.title_id, leaf_1.title, leaf_1.price, leaf_1.pub_id, leaf_1.pub_name, (leaf_1.price * leaf_1.qty) AS revenue\nFROM (SELECT stores.stor_id, stores.city, stores.state AS stor_state, sales.ord_num, sales.ord_date, sales.qty, sales.payterms, sales.title_id, titles.title, titles.price, titles.pub_id, publishers.pub_name, publishers.state AS pub_state\nFROM stores\nJOIN sales ON stores.stor_id = sales.stor_id\nJOIN titles ON sales.title_id = titles.title_id\nJOIN publishers ON titles.pub_id = publishers.pub_id\nWHERE (stores.state = 'CA') AND (publishers.state = 'CA') AND (publishers.pub_id = '1389')) AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT stores.stor_id, stores.city, stores.state AS stor_state, sales.ord_num, sales.ord_date, sales.qty, sales.payterms, sales.title_id, titles.title, titles.price, titles.pub_id, publishers.pub_name, publishers.state AS pub_state",
        "from_clause": "FROM stores",
        "join_clauses": [
          "JOIN sales ON stores.stor_id = sales.stor_id",
          "JOIN titles ON sales.title_id = titles.title_id",
          "JOIN publishers ON titles.pub_id = publishers.pub_id"
        ],
        "where_clauses": [
          "stores.state = 'CA'",
          "publishers.state = 'CA'",
          "publishers.pub_id = '1389'"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "sales of titles published by Algodata Infosystems in California, made in stores located in California"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(leaf_1.price * leaf_1.qty) AS total_revenue",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "total revenue from sales of titles published by Algodata Infosystems in California, made in stores located in California"
      }
