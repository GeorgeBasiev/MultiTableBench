  "plan": {
    "question_intent": "count of authors who have written books published by Algodata Infosystems and have a contract",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT a.au_id, a.au_lname, a.au_fname, t.title, t.pub_id, p.pub_name FROM authors AS a JOIN titleauthor AS ta ON a.au_id = ta.au_id JOIN titles AS t ON ta.title_id = t.title_id JOIN publishers AS p ON t.pub_id = p.pub_id WHERE p.pub_id = '1389' AND a.contract = 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT a.au_id, COUNT(DISTINCT a.au_id) AS author_count",
        "from_clause": "FROM authors AS a",
        "join_clauses": [
          "JOIN titleauthor AS ta ON a.au_id = ta.au_id",
          "JOIN titles AS t ON ta.title_id = t.title_id"
        ],
        "where_clauses": [
          "t.pub_id = '1389'",
          "a.contract = 1"
        ],
        "group_by_clause": "GROUP BY a.au_id",
        "having_clauses": [
          "COUNT(DISTINCT a.au_id) > 0"
        ],
        "notes": "count of authors who have written books published by Algodata Infosystems and have a contract"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(leaf_1.author_count) AS total_authors",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "final scalar block"
      }
