  "plan": {
    "question_intent": "average price of titles authored by authors who have contracts",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT t.title_id, t.title, t.price, a.au_id, a.au_lname, a.au_fname, a.contract FROM titles AS t JOIN titleauthor AS ta ON t.title_id = ta.title_id JOIN authors AS a ON ta.au_id = a.au_id WHERE a.contract = 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT t.title_id, t.title, t.price, a.au_id, a.au_lname, a.au_fname, a.contract",
        "from_clause": "FROM titles AS t",
        "join_clauses": [
          "JOIN titleauthor AS ta ON t.title_id = ta.title_id",
          "JOIN authors AS a ON ta.au_id = a.au_id"
        ],
        "where_clauses": [
          "a.contract = 1"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "returns titles, authors, and their contracts where authors have contracts"
