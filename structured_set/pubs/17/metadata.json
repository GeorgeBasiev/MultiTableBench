  "plan": {
    "question_intent": "Calculate the total sales amount for titles published by Algodata Infosystems in California, including discounts applied.",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT t.title_id, t.title, t.price, s.qty, s.stor_id, (t.price * s.qty) AS gross_amount, d.discount, (t.price * s.qty * (100 - d.discount) / 100) AS discounted_amount FROM titles t JOIN sales s ON t.title_id = s.title_id JOIN discounts d ON s.stor_id = d.stor_id WHERE t.pub_id = '1389' AND t.pub_id IN (SELECT pub_id FROM publishers WHERE state = 'CA')",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT t.title_id, t.title, t.price, s.qty, s.stor_id, (t.price * s.qty) AS gross_amount, d.discount, (t.price * s.qty * (100 - d.discount) / 100) AS discounted_amount",
        "from_clause": "FROM titles t",
        "join_clauses": [
          "JOIN sales s ON t.title_id = s.title_id",
          "JOIN discounts d ON s.stor_id = d.stor_id"
        ],
        "where_clauses": [
          "t.pub_id = '1389'",
          "t.pub_id IN (SELECT pub_id FROM publishers WHERE state = 'CA')"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Calculates the discounted sales amount for each title sold, including the gross amount and discount applied"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(discounted_amount) AS total_sales_amount",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Aggregates the discounted sales amounts to calculate the total sales amount"
      }
    ]
  },
