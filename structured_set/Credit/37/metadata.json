  "plan": {
    "question_intent": "Total payment amount for members in the Scandanavian region who have charges in the Lodging category",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT payment.payment_no, payment.member_no, payment.payment_dt, payment.payment_amt, payment.statement_no, payment.payment_code FROM payment JOIN member ON payment.member_no = member.member_no JOIN region ON member.region_no = region.region_no JOIN charge ON member.member_no = charge.member_no JOIN category ON charge.category_no = category.category_no WHERE region.region_name = 'Scandanavian' AND category.category_desc = 'Lodging'",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT payment.member_no, payment.payment_amt",
        "from_clause": "FROM payment",
        "join_clauses": [
          "JOIN member ON payment.member_no = member.member_no",
          "JOIN region ON member.region_no = region.region_no",
          "JOIN charge ON member.member_no = charge.member_no"
        ],
        "where_clauses": [
          "region.region_name = 'Scandanavian'",
          "EXISTS (SELECT 1 FROM category WHERE charge.category_no = category.category_no AND category.category_desc = 'Lodging')"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Filter payments for members in the Scandanavian region who have charges in the Lodging category"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(leaf_1.payment_amt)",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Calculate the total payment amount for the filtered payments"
      }
    ]
  },
