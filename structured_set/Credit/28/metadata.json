  "plan": {
    "question_intent": "Calculate the average charge amount for members in regions with a high average payment amount, excluding charges in the 'Travel' category.",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_2.region_name, leaf_2.charge_amt, leaf_2.payment_amt\nFROM (SELECT r.region_name, c.charge_no, c.charge_amt, p.payment_no, p.payment_amt\nFROM charge AS c\nJOIN member AS m ON c.member_no = m.member_no\nJOIN region AS r ON m.region_no = r.region_no\nJOIN payment AS p ON m.member_no = p.member_no\nJOIN category AS cat ON c.category_no = cat.category_no\nWHERE cat.category_desc != 'Travel'\nGROUP BY r.region_name, c.charge_no, c.charge_amt, p.payment_no, p.payment_amt) AS leaf_2\nWHERE leaf_2.payment_amt > (SELECT AVG(payment_amt) FROM payment)\nGROUP BY leaf_2.region_name, leaf_2.charge_amt, leaf_2.payment_amt",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT r.region_name, c.charge_no, c.charge_amt, p.payment_no, p.payment_amt",
        "from_clause": "FROM charge AS c",
        "join_clauses": [
          "JOIN member AS m ON c.member_no = m.member_no",
          "JOIN region AS r ON m.region_no = r.region_no",
          "JOIN payment AS p ON m.member_no = p.member_no",
          "JOIN category AS cat ON c.category_no = cat.category_no"
        ],
        "where_clauses": [
          "cat.category_desc != 'Travel'"
        ],
        "group_by_clause": "GROUP BY r.region_name, c.charge_no, c.charge_amt, p.payment_no, p.payment_amt",
        "having_clauses": [],
        "notes": "Returns charge details along with payment details for each region, excluding 'Travel' category charges."
      },
      {
        "name": "leaf_2",
        "role": "intermediate",
        "select_clause": "SELECT leaf_1.region_name, leaf_1.charge_no, leaf_1.charge_amt, leaf_1.payment_no, leaf_1.payment_amt",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [
          "leaf_1.payment_amt > (SELECT AVG(payment_amt) FROM payment)"
        ],
        "group_by_clause": "GROUP BY leaf_1.region_name, leaf_1.charge_no, leaf_1.charge_amt, leaf_1.payment_no, leaf_1.payment_amt",
        "having_clauses": [],
        "notes": "Filters charges based on payment amounts greater than the average payment amount."
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_2.charge_amt)",
        "from_clause": "FROM {{leaf_2}} AS leaf_2",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Calculates the average charge amount for the filtered charges."
      }
    ]
  },
