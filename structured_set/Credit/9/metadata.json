  "plan": {
    "question_intent": "Average charge amount for members in the North American region who made payments in August 1999",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.member_no, leaf_1.firstname, leaf_1.lastname, leaf_1.charge_no, leaf_1.charge_dt, leaf_1.charge_amt FROM {{leaf_1}} AS leaf_1 WHERE leaf_1.region_name = 'North American' AND leaf_1.payment_dt BETWEEN '1999-08-01' AND '1999-08-31'",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT m.member_no, m.firstname, m.lastname, c.charge_no, c.charge_dt, c.charge_amt, p.payment_dt, r.region_name",
        "from_clause": "FROM member AS m",
        "join_clauses": [
          "JOIN charge AS c ON m.member_no = c.member_no",
          "JOIN payment AS p ON m.member_no = p.member_no",
          "JOIN region AS r ON m.region_no = r.region_no"
        ],
        "where_clauses": [
          "r.region_name = 'North American'",
          "p.payment_dt BETWEEN '1999-08-01' AND '1999-08-31'"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Retrieves member details, charge information, payment dates, and region names for members in the North American region who made payments in August 1999"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.charge_amt)",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
