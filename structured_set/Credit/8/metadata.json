  "plan": {
    "question_intent": "total charges for meals in the North American region",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.category_no, leaf_1.region_no, leaf_1.total_charges FROM (SELECT c.category_no, p.region_no, SUM(ch.charge_amt) AS total_charges FROM charge AS ch JOIN category AS c ON ch.category_no = c.category_no JOIN provider AS p ON ch.provider_no = p.provider_no WHERE c.category_desc = 'Meals' GROUP BY c.category_no, p.region_no) AS leaf_1 WHERE leaf_1.region_no = 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.category_no, p.region_no, SUM(ch.charge_amt) AS total_charges",
        "from_clause": "FROM charge AS ch",
        "join_clauses": [
          "JOIN category AS c ON ch.category_no = c.category_no",
          "JOIN provider AS p ON ch.provider_no = p.provider_no"
        ],
        "where_clauses": [
          "c.category_desc = 'Meals'"
        ],
        "group_by_clause": "GROUP BY c.category_no, p.region_no",
        "having_clauses": [],
        "notes": "sum of charges for meals grouped by category and region"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(leaf_1.total_charges) AS total_meals_charges",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [
          "leaf_1.region_no = 1"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "total charges for meals in the North American region"
      }
    ]
  },
