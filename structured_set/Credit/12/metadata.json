  "plan": {
    "question_intent": "average charge amount for members in North American and South American regions",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.charge_no, c.charge_dt, c.charge_amt, m.firstname, m.lastname, r.region_name FROM charge AS c JOIN member AS m ON c.member_no = m.member_no JOIN region AS r ON m.region_no = r.region_no WHERE r.region_name = 'North American' OR r.region_name = 'South American'",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.charge_amt, r.region_name",
        "from_clause": "FROM charge AS c",
        "join_clauses": [
          "JOIN member AS m ON c.member_no = m.member_no",
          "JOIN region AS r ON m.region_no = r.region_no"
        ],
        "where_clauses": [
          "r.region_name = 'North American' OR r.region_name = 'South American'"
        ],
        "group_by_clause": "GROUP BY c.charge_no, r.region_name",
        "having_clauses": [],
        "notes": "charge amounts and region names for members in North American and South American regions"
      },
