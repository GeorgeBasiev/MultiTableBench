  "plan": {
    "question_intent": "average charge amount for members in the China and Africa regions who have made payments in the year 2000",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT m.region_no, r.region_name, m.member_no, m.lastname, m.firstname, c.charge_dt, c.charge_amt\nFROM charge AS c\nJOIN member AS m ON c.member_no = m.member_no\nJOIN region AS r ON m.region_no = r.region_no\nJOIN payment AS p ON m.member_no = p.member_no\nWHERE r.region_name IN ('China', 'Africa')\nAND strftime('%Y', p.payment_dt) = '2000'\nGROUP BY m.region_no, r.region_name, m.member_no, m.lastname, m.firstname, c.charge_dt, c.charge_amt",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT m.region_no, r.region_name, m.member_no, AVG(c.charge_amt) AS avg_charge_amt",
        "from_clause": "FROM charge AS c",
        "join_clauses": [
          "JOIN member AS m ON c.member_no = m.member_no",
          "JOIN region AS r ON m.region_no = r.region_no",
          "JOIN payment AS p ON m.member_no = p.member_no"
        ],
        "where_clauses": [
          "r.region_name IN ('China', 'Africa')",
          "strftime('%Y', p.payment_dt) = '2000'"
        ],
        "group_by_clause": "GROUP BY m.region_no, r.region_name, m.member_no",
        "having_clauses": [],
        "notes": "average charge amount for members in the China and Africa regions who have made payments in the year 2000"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.avg_charge_amt) AS final_avg_charge_amt",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "final scalar block"
      }
    ]
  },
