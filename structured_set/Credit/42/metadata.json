  "plan": {
    "question_intent": "Find the name of the provider with the highest total charge amount in the Meals category",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT c.charge_no, c.charge_dt, c.charge_amt, p.provider_name FROM charge c JOIN provider p ON c.provider_no = p.provider_no JOIN category cat ON c.category_no = cat.category_no WHERE cat.category_desc = 'Meals' ORDER BY c.charge_amt DESC",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT p.provider_name, SUM(c.charge_amt) AS total_charge",
        "from_clause": "FROM charge c",
        "join_clauses": [
          "JOIN provider p ON c.provider_no = p.provider_no",
          "JOIN category cat ON c.category_no = cat.category_no"
        ],
        "where_clauses": [
          "cat.category_desc = 'Meals'"
        ],
        "group_by_clause": "GROUP BY p.provider_name",
        "having_clauses": [],
        "notes": "This block calculates the total charge amount for each provider in the Meals category"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT provider_name",
        "from_clause": "FROM (SELECT provider_name, total_charge FROM {{leaf_1}} ORDER BY total_charge DESC LIMIT 1) AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "This block returns the name of the provider with the highest total charge amount in the Meals category"
      }
    ]
  },
