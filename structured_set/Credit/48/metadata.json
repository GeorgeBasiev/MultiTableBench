  "plan": {
    "question_intent": "total amount of charges for members from regions with names containing 'American'",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.region_name, leaf_1.total_charges FROM (SELECT r.region_name, SUM(c.charge_amt) AS total_charges FROM charge AS c JOIN member AS m ON c.member_no = m.member_no JOIN region AS r ON m.region_no = r.region_no WHERE r.region_name LIKE '%American%' GROUP BY r.region_name) AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT r.region_name, SUM(c.charge_amt) AS total_charges",
        "from_clause": "FROM charge AS c",
        "join_clauses": [
          "JOIN member AS m ON c.member_no = m.member_no",
          "JOIN region AS r ON m.region_no = r.region_no"
        ],
        "where_clauses": [
          "r.region_name LIKE '%American%'"
        ],
        "group_by_clause": "GROUP BY r.region_name",
        "having_clauses": [],
        "notes": "returns the total charges for each region with a name containing 'American'"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(leaf_1.total_charges) AS total_amount",
        "from_clause": "FROM (SELECT r.region_name, SUM(c.charge_amt) AS total_charges FROM charge AS c JOIN member AS m ON c.member_no = m.member_no JOIN region AS r ON m.region_no = r.region_no WHERE r.region_name LIKE '%American%' GROUP BY r.region_name) AS leaf_1",
        "join_clauses": [],
