  "plan": {
    "question_intent": "name of the corporation that has the highest total charge amount from the provider located in the North American region",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.corp_name, leaf_1.provider_name, leaf_1.total_charge FROM (SELECT c.corp_no, c.corp_name, p.provider_name, SUM(ch.charge_amt) AS total_charge FROM charge AS ch JOIN provider AS p ON ch.provider_no = p.provider_no JOIN region AS r ON p.region_no = r.region_no JOIN corporation AS c ON ch.member_no = c.corp_no WHERE r.region_name = 'North American' GROUP BY c.corp_no, c.corp_name, p.provider_name ORDER BY total_charge DESC) AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.corp_no, c.corp_name, p.provider_name, SUM(ch.charge_amt) AS total_charge",
        "from_clause": "FROM charge AS ch",
        "join_clauses": [
          "JOIN provider AS p ON ch.provider_no = p.provider_no",
          "JOIN region AS r ON p.region_no = r.region_no",
          "JOIN corporation AS c ON ch.member_no = c.corp_no"
        ],
        "where_clauses": [
          "r.region_name = 'North American'"
        ],
        "group_by_clause": "GROUP BY c.corp_no, c.corp_name, p.provider_name",
        "having_clauses": [],
        "notes": "total charge amounts by corporation and provider in the North American region"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT leaf_1.corp_name",
        "from_clause": "FROM (SELECT leaf_1.corp_no, leaf_1.corp_name, leaf_1.provider_name, leaf_1.total_charge FROM {{leaf_1}} AS leaf_1 ORDER BY leaf_1.total_charge DESC LIMIT 1) AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "name of the corporation with the highest total charge amount from the provider located in the North American region"
      }
    ]
  },
