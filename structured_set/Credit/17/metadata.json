  "plan": {
    "question_intent": "Calculate the average charge amount for members who have made payments in the 'North American' region",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.charge_no, c.member_no, c.charge_dt, c.charge_amt, m.region_no, r.region_name FROM charge AS c JOIN member AS m ON c.member_no = m.member_no JOIN region AS r ON m.region_no = r.region_no WHERE c.member_no IN (SELECT DISTINCT p.member_no FROM payment AS p) AND r.region_name = 'North American'",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT DISTINCT p.member_no",
        "from_clause": "FROM payment AS p",
