  "plan": {
    "question_intent": "Average payment amount for members in the 'North American' region who have made charges in the 'Travel' category",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT p.payment_no, p.member_no, p.payment_dt, p.payment_amt, p.statement_no, p.payment_code, m.region_no, r.region_name, c.category_no, c.category_desc FROM payment p JOIN member m ON p.member_no = m.member_no JOIN region r ON m.region_no = r.region_no JOIN charge ch ON p.member_no = ch.member_no JOIN category c ON ch.category_no = c.category_no WHERE r.region_name = 'North American' AND c.category_desc = 'Travel' GROUP BY p.payment_no, p.member_no, p.payment_dt, p.payment_amt, p.statement_no, p.payment_code, m.region_no, r.region_name, c.category_no, c.category_desc",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT p.payment_no, p.member_no, p.payment_dt, p.payment_amt, p.statement_no, p.payment_code, m.region_no, r.region_name, c.category_no, c.category_desc",
        "from_clause": "FROM payment p",
        "join_clauses": [
          "JOIN member m ON p.member_no = m.member_no",
          "JOIN region r ON m.region_no = r.region_no",
          "JOIN charge ch ON p.member_no = ch.member_no",
          "JOIN category c ON ch.category_no = c.category_no"
        ],
        "where_clauses": [
          "r.region_name = 'North American'",
          "c.category_desc = 'Travel'"
        ],
        "group_by_clause": "GROUP BY p.payment_no, p.member_no, p.payment_dt, p.payment_amt, p.statement_no, p.payment_code, m.region_no, r.region_name, c.category_no, c.category_desc",
        "having_clauses": [],
        "notes": "Payments for members in North American region with charges in Travel category"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.payment_amt)",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
