  "plan": {
    "question_intent": "The name of the region with the highest average payment amount per member for members who have made payments in the 'Meals' category",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.region_name, leaf_1.avg_payment_per_member FROM {{leaf_1}} AS leaf_1 ORDER BY leaf_1.avg_payment_per_member DESC LIMIT 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT r.region_name, AVG(p.payment_amt) AS avg_payment_per_member",
        "from_clause": "FROM payment AS p",
        "join_clauses": [
          "JOIN member AS m ON p.member_no = m.member_no",
          "JOIN region AS r ON m.region_no = r.region_no",
          "JOIN charge AS c ON p.member_no = c.member_no AND p.statement_no = c.statement_no",
          "JOIN category AS cat ON c.category_no = cat.category_no"
        ],
        "where_clauses": [
          "cat.category_desc = 'Meals'"
        ],
        "group_by_clause": "GROUP BY r.region_name",
        "having_clauses": [],
        "notes": "Calculates the average payment amount per member for each region, filtered by payments made in the 'Meals' category"
