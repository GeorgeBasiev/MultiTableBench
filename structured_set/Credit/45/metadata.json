  "plan": {
    "question_intent": "average amount spent by members in the North American region on charges categorized as 'Travel'",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT m.member_no, m.lastname, m.firstname, c.charge_no, c.charge_dt, c.charge_amt, cat.category_desc FROM member AS m JOIN charge AS c ON m.member_no = c.member_no JOIN region AS r ON m.region_no = r.region_no JOIN category AS cat ON c.category_no = cat.category_no WHERE r.region_name = 'North American' AND cat.category_desc = 'Travel'",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT m.member_no, SUM(c.charge_amt) AS total_spent",
        "from_clause": "FROM member AS m",
        "join_clauses": [
          "JOIN charge AS c ON m.member_no = c.member_no",
          "JOIN region AS r ON m.region_no = r.region_no"
        ],
        "where_clauses": [
          "r.region_name = 'North American'",
          "c.category_no = (SELECT category_no FROM category WHERE category_desc = 'Travel')"
        ],
        "group_by_clause": "GROUP BY m.member_no",
        "having_clauses": [
          "SUM(c.charge_amt) > 0"
        ],
        "notes": "total spent by members in the North American region on 'Travel' charges"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.total_spent)",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
