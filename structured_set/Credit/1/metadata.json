  "plan": {
    "question_intent": "average charge amount for members in regions 1, 2, 3, or 4 who have made payments in the same year as their charges",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.charge_no, c.charge_dt, c.charge_amt, m.member_no, m.region_no, p.payment_no, p.payment_dt FROM charge AS c JOIN member AS m ON c.member_no = m.member_no JOIN payment AS p ON c.member_no = p.member_no JOIN corporation AS co ON m.corp_no = co.corp_no WHERE (co.region_no IN (1, 2, 3, 4)) AND (strftime('%Y', c.charge_dt) = strftime('%Y', p.payment_dt))",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.charge_no, c.charge_dt, c.charge_amt, m.member_no, m.region_no, p.payment_no, p.payment_dt",
        "from_clause": "FROM charge AS c",
        "join_clauses": [
          "JOIN member AS m ON c.member_no = m.member_no",
          "JOIN payment AS p ON c.member_no = p.member_no",
          "JOIN corporation AS co ON m.corp_no = co.corp_no"
        ],
        "where_clauses": [
          "co.region_no IN (1, 2, 3, 4)",
          "strftime('%Y', c.charge_dt) = strftime('%Y', p.payment_dt)"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "joins charge, member, payment, and corporation tables to filter charges by region and ensure payments were made in the same year as the charge"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.charge_amt)",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "calculates the average charge amount from the filtered charges"
      }
    ]
  },
