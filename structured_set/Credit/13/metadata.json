  "plan": {
    "question_intent": "name of the corporation with the highest total charge amount for the month of August 1999",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT c.corp_name, SUM(ch.charge_amt) AS total_charge FROM corporation c JOIN member m ON c.corp_no = m.corp_no JOIN charge ch ON m.member_no = ch.member_no WHERE strftime('%Y-%m', ch.charge_dt) = '1999-08' GROUP BY c.corp_name ORDER BY total_charge DESC LIMIT 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.corp_name, SUM(ch.charge_amt) AS total_charge",
        "from_clause": "FROM corporation c",
        "join_clauses": [
          "JOIN member m ON c.corp_no = m.corp_no",
          "JOIN charge ch ON m.member_no = ch.member_no"
        ],
        "where_clauses": [
          "strftime('%Y-%m', ch.charge_dt) = '1999-08'"
        ],
        "group_by_clause": "GROUP BY c.corp_name",
        "having_clauses": [],
        "notes": "returns corporation name and total charge amount for each corporation for August 1999"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT leaf_1.corp_name",
        "from_clause": "FROM (SELECT c.corp_name, SUM(ch.charge_amt) AS total_charge FROM corporation c JOIN member m ON c.corp_no = m.corp_no JOIN charge ch ON m.member_no = ch.member_no WHERE strftime('%Y-%m', ch.charge_dt) = '1999-08' GROUP BY c.corp_name ORDER BY total_charge DESC LIMIT 1) AS leaf_1",
        "join_clauses": [],
