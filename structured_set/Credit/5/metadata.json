  "plan": {
    "question_intent": "total payment amount for members in regions where the average charge amount is greater than 5000",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.payment_no, leaf_1.payment_dt, leaf_1.payment_amt, leaf_1.region_name FROM (SELECT p.payment_no, p.payment_dt, p.payment_amt, r.region_name FROM payment AS p JOIN member AS m ON p.member_no = m.member_no JOIN region AS r ON m.region_no = r.region_no JOIN charge AS c ON p.member_no = c.member_no GROUP BY p.payment_no, p.payment_dt, p.payment_amt, r.region_name HAVING AVG(c.charge_amt) > 5000) AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT p.payment_no, p.payment_dt, p.payment_amt, r.region_name",
        "from_clause": "FROM payment AS p",
        "join_clauses": [
          "JOIN member AS m ON p.member_no = m.member_no",
          "JOIN region AS r ON m.region_no = r.region_no",
          "JOIN charge AS c ON p.member_no = c.member_no"
        ],
        "where_clauses": [],
        "group_by_clause": "GROUP BY p.payment_no, p.payment_dt, p.payment_amt, r.region_name",
        "having_clauses": [
          "AVG(c.charge_amt) > 5000"
        ],
        "notes": "payment details with region names for regions where average charge amount is greater than 5000"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(leaf_1.payment_amt)",
