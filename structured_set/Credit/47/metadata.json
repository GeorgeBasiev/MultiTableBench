  "plan": {
    "question_intent": "Find the name of the provider who has the highest total charge amount for the category 'Meals'",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT provider.provider_name, category.category_desc, charge.charge_amt FROM charge JOIN provider ON charge.provider_no = provider.provider_no JOIN category ON charge.category_no = category.category_no WHERE category.category_desc = 'Meals'",
    "blocks": [
