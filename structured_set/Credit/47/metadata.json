        "name": "root",
        "role": "root",
        "select_clause": "SELECT provider_name",
        "from_clause": "FROM (SELECT leaf_1.provider_no, leaf_1.total_charge FROM {{leaf_1}} AS leaf_1 ORDER BY leaf_1.total_charge DESC LIMIT 1) AS highest_charge_provider JOIN provider ON highest_charge_provider.provider_no = provider.provider_no",
