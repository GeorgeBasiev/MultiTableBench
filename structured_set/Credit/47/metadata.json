        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT provider_no, SUM(charge_amt) AS total_charge",
        "from_clause": "FROM charge",
        "join_clauses": [
          "JOIN category ON charge.category_no = category.category_no"
        ],
        "where_clauses": [
          "category.category_desc = 'Meals'"
        ],
        "group_by_clause": "GROUP BY charge.provider_no",
        "having_clauses": [],
        "notes": "This block calculates the total charge amount for each provider in the 'Meals' category"
      },
