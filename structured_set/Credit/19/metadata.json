  "plan": {
    "question_intent": "total amount of charges made in the North American and South American regions in the month of October 1999",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.charge_no, leaf_1.charge_dt, leaf_1.charge_amt, leaf_1.region_name\nFROM (SELECT c.charge_no, c.charge_dt, c.charge_amt, r.region_name\nFROM charge c\nJOIN member m ON c.member_no = m.member_no\nJOIN region r ON m.region_no = r.region_no\nWHERE (r.region_name = 'North American' OR r.region_name = 'South American') AND strftime('%Y-%m', c.charge_dt) = '1999-10') AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.charge_no, c.charge_dt, c.charge_amt, r.region_name",
        "from_clause": "FROM charge c",
        "join_clauses": [
          "JOIN member m ON c.member_no = m.member_no",
          "JOIN region r ON m.region_no = r.region_no"
        ],
        "where_clauses": [
          "r.region_name = 'North American' OR r.region_name = 'South American'",
          "strftime('%Y-%m', c.charge_dt) = '1999-10'"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "charges made in the North American and South American regions in October 1999"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(leaf_1.charge_amt) AS total_charge_amount",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "total amount of charges made in the North American and South American regions in October 1999"
      }
    ]
  },
