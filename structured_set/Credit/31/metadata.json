  "plan": {
    "question_intent": "total charge amount for members in the 'North American' region who have made payments and have charges categorized as 'Travel'",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.charge_no, leaf_1.charge_dt, leaf_1.charge_amt, leaf_1.member_no, leaf_1.lastname, leaf_1.firstname, leaf_1.region_name FROM (SELECT c.charge_no, c.charge_dt, c.charge_amt, m.member_no, m.lastname, m.firstname, r.region_name FROM charge AS c JOIN member AS m ON c.member_no = m.member_no JOIN payment AS p ON m.member_no = p.member_no JOIN region AS r ON m.region_no = r.region_no WHERE r.region_name = 'North American' AND c.category_no = (SELECT category_no FROM category WHERE category_desc = 'Travel')) AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.charge_no, c.charge_dt, c.charge_amt, m.member_no, m.lastname, m.firstname, r.region_name",
        "from_clause": "FROM charge AS c",
        "join_clauses": [
          "JOIN member AS m ON c.member_no = m.member_no",
          "JOIN payment AS p ON m.member_no = p.member_no",
          "JOIN region AS r ON m.region_no = r.region_no"
        ],
        "where_clauses": [
          "r.region_name = 'North American'",
          "c.category_no = (SELECT category_no FROM category WHERE category_desc = 'Travel')"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "charges for members in the North American region who have made payments and have charges categorized as 'Travel'"
