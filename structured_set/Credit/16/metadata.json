  "plan": {
    "question_intent": "Average charge amount by category for members from the North American region",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.category_desc, m.region_no, ch.charge_amt FROM charge ch JOIN member m ON ch.member_no = m.member_no JOIN category c ON ch.category_no = c.category_no WHERE m.region_no = 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.category_no, c.category_desc, AVG(ch.charge_amt) AS avg_charge",
        "from_clause": "FROM charge ch",
        "join_clauses": [
          "JOIN member m ON ch.member_no = m.member_no",
          "JOIN category c ON ch.category_no = c.category_no"
        ],
        "where_clauses": [
          "m.region_no = 1"
        ],
        "group_by_clause": "GROUP BY c.category_no, c.category_desc",
        "having_clauses": [],
        "notes": "Average charge amount by category for members from the North American region"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.avg_charge) AS overall_avg_charge",
