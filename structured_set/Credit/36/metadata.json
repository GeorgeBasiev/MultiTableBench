  "plan": {
    "question_intent": "Find the name of the provider who issued the most expensive charge in the Lodging category",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT c.charge_no, c.charge_dt, c.charge_amt, p.provider_name FROM charge AS c JOIN provider AS p ON c.provider_no = p.provider_no JOIN category AS cat ON c.category_no = cat.category_no WHERE cat.category_desc = 'Lodging' ORDER BY c.charge_amt DESC LIMIT 1",
