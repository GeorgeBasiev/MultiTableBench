  "plan": {
    "question_intent": "total payments made by members in the North American region in August 1999",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.payment_no, leaf_1.payment_dt, leaf_1.payment_amt, leaf_1.region_name FROM (SELECT p.payment_no, p.payment_dt, p.payment_amt, r.region_name FROM payment AS p JOIN member AS m ON p.member_no = m.member_no JOIN region AS r ON m.region_no = r.region_no WHERE (r.region_name = 'North American') AND (strftime('%Y-%m', p.payment_dt) = '1999-08')) AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT p.payment_no, p.payment_dt, p.payment_amt, r.region_name",
        "from_clause": "FROM payment AS p",
        "join_clauses": [
          "JOIN member AS m ON p.member_no = m.member_no",
          "JOIN region AS r ON m.region_no = r.region_no"
        ],
        "where_clauses": [
          "r.region_name = 'North American'",
          "strftime('%Y-%m', p.payment_dt) = '1999-08'"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "payments made by members in the North American region in August 1999"
      },
      {
        "name": "root",
