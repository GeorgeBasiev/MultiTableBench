  "plan": {
    "question_intent": "Find the name of the corporation with the highest total charge amount for charges made in the South American region by providers in the Scandanavian region",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.corp_name, leaf_1.total_charge_amt FROM (SELECT corp.corp_name, SUM(c.charge_amt) AS total_charge_amt, m.region_no AS member_region_no, p.region_no AS provider_region_no FROM charge AS c JOIN member AS m ON c.member_no = m.member_no JOIN corporation AS corp ON m.corp_no = corp.corp_no JOIN provider AS p ON c.provider_no = p.provider_no WHERE (m.region_no = 2) AND (p.region_no = 3) GROUP BY corp.corp_name, m.region_no, p.region_no) AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT corp.corp_name, SUM(c.charge_amt) AS total_charge_amt, m.region_no AS member_region_no, p.region_no AS provider_region_no",
        "from_clause": "FROM charge AS c",
        "join_clauses": [
          "JOIN member AS m ON c.member_no = m.member_no",
          "JOIN corporation AS corp ON m.corp_no = corp.corp_no",
          "JOIN provider AS p ON c.provider_no = p.provider_no"
        ],
        "where_clauses": [
          "(m.region_no = 2)",
          "(p.region_no = 3)"
        ],
        "group_by_clause": "GROUP BY corp.corp_name, m.region_no, p.region_no",
        "having_clauses": [],
        "notes": "This block calculates the total charge amount for each corporation, filtering for members in the South American region and providers in the Scandanavian region."
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT leaf_1.corp_name",
        "from_clause": "FROM (SELECT leaf_1.corp_name, MAX(leaf_1.total_charge_amt) AS max_charge_amt FROM {{leaf_1}} AS leaf_1 GROUP BY leaf_1.corp_name) AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "This block finds the corporation with the highest total charge amount from the previous block."
      }
    ]
  },
