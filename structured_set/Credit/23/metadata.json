  "plan": {
    "question_intent": "The name of the member who made the highest payment in the region with the most providers",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT p.payment_no, p.member_no, m.lastname, m.firstname, r.region_name FROM {{leaf_1}} AS leaf_1 JOIN payment AS p ON leaf_1.member_no = p.member_no JOIN member AS m ON p.member_no = m.member_no JOIN region AS r ON m.region_no = r.region_no ORDER BY p.payment_amt DESC LIMIT 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT r.region_no, r.region_name, COUNT(p.provider_no) AS provider_count",
        "from_clause": "FROM region AS r",
        "join_clauses": [
          "JOIN provider AS p ON r.region_no = p.region_no"
        ],
        "where_clauses": [],
        "group_by_clause": "GROUP BY r.region_no, r.region_name",
        "having_clauses": [],
        "notes": "Counts providers per region"
      },
      {
        "name": "leaf_2",
        "role": "leaf",
        "select_clause": "SELECT m.member_no, m.region_no",
        "from_clause": "FROM member AS m",
        "join_clauses": [],
        "where_clauses": [
          "m.region_no = (SELECT leaf_1.region_no FROM {{leaf_1}} AS leaf_1 ORDER BY leaf_1.provider_count DESC LIMIT 1)"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Selects members in the region with the most providers"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT m.lastname || ' ' || m.firstname",
        "from_clause": "FROM {{leaf_2}} AS leaf_2 JOIN payment AS p ON leaf_2.member_no = p.member_no JOIN member AS m ON p.member_no = m.member_no",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Final scalar block returning the name of the member with the highest payment in the region with the most providers"
      }
    ]
  },
