  "plan": {
    "question_intent": "Average charge amount per category for members in the North American region",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.category_desc, m.member_no, ch.charge_no, ch.charge_amt FROM charge AS ch JOIN member AS m ON ch.member_no = m.member_no JOIN category AS c ON ch.category_no = c.category_no JOIN region AS r ON m.region_no = r.region_no WHERE r.region_name = 'North American' GROUP BY c.category_desc, m.member_no, ch.charge_no, ch.charge_amt",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.category_desc, AVG(ch.charge_amt) AS avg_charge_amt",
        "from_clause": "FROM charge AS ch",
        "join_clauses": [
          "JOIN member AS m ON ch.member_no = m.member_no",
          "JOIN category AS c ON ch.category_no = c.category_no"
        ],
        "where_clauses": [
          "m.region_no = 1"
        ],
        "group_by_clause": "GROUP BY c.category_desc",
        "having_clauses": [],
        "notes": "Calculates the average charge amount for each category for members in the North American region"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.avg_charge_amt) AS average_charge_amount",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Final scalar block that calculates the average charge amount across all categories for members in the North American region"
      }
    ]
  },
