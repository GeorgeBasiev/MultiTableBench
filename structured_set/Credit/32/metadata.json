  "plan": {
    "question_intent": "Calculate the average payment amount for members from regions where the total number of charges is greater than 5000",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.region_name, leaf_1.payment_dt, leaf_1.payment_amt FROM (SELECT r.region_name, p.payment_dt, p.payment_amt, m.region_no, COUNT(c.charge_no) AS charge_count FROM payment AS p JOIN member AS m ON p.member_no = m.member_no JOIN region AS r ON m.region_no = r.region_no JOIN charge AS c ON m.member_no = c.member_no GROUP BY m.region_no, r.region_name, p.payment_dt, p.payment_amt HAVING COUNT(c.charge_no) > 5000) AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT r.region_name, p.payment_dt, p.payment_amt, m.region_no, COUNT(c.charge_no) AS charge_count",
        "from_clause": "FROM payment AS p",
        "join_clauses": [
          "JOIN member AS m ON p.member_no = m.member_no",
          "JOIN region AS r ON m.region_no = r.region_no",
          "JOIN charge AS c ON m.member_no = c.member_no"
        ],
        "where_clauses": [],
        "group_by_clause": "GROUP BY m.region_no, r.region_name, p.payment_dt, p.payment_amt",
        "having_clauses": [
          "COUNT(c.charge_no) > 5000"
        ],
        "notes": "This block returns the region name, payment date, payment amount, region number, and the count of charges for each member, filtered by regions with more than 5000 charges"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.payment_amt)",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "This block calculates the average payment amount for members from regions with more than 5000 charges"
      }
    ]
  },
