  "plan": {
    "question_intent": "average charge amount per category for members in region 5",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.category_desc, AVG(ch.charge_amt) AS avg_charge_amount FROM charge ch JOIN member m ON ch.member_no = m.member_no JOIN category c ON ch.category_no = c.category_no WHERE m.region_no = 5 GROUP BY c.category_desc ORDER BY avg_charge_amount DESC",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.category_desc, AVG(ch.charge_amt) AS avg_charge_amount",
        "from_clause": "FROM charge ch",
        "join_clauses": [
          "JOIN member m ON ch.member_no = m.member_no",
          "JOIN category c ON ch.category_no = c.category_no"
        ],
        "where_clauses": [
          "m.region_no = 5"
        ],
        "group_by_clause": "GROUP BY c.category_desc",
        "having_clauses": [],
        "notes": "average charge amount per category for members in region 5"
      },
