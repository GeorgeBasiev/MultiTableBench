  "plan": {
    "question_intent": "Find the name of the provider who provided the largest charge for a member from a South American region",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT m.member_no, m.lastname, m.firstname, c.category_desc, ch.charge_amt, p.provider_name FROM member m JOIN charge ch ON m.member_no = ch.member_no JOIN category c ON ch.category_no = c.category_no JOIN provider p ON ch.provider_no = p.provider_no JOIN region r ON m.region_no = r.region_no WHERE r.region_name = 'South American' ORDER BY ch.charge_amt DESC LIMIT 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT p.provider_name",
        "from_clause": "FROM (SELECT ch.charge_amt, ch.provider_no FROM (SELECT m.member_no FROM member m JOIN region r ON m.region_no = r.region_no WHERE r.region_name = 'South American') AS south_american_members JOIN charge ch ON south_american_members.member_no = ch.member_no ORDER BY ch.charge_amt DESC LIMIT 1) AS max_charge",
        "join_clauses": [
          "JOIN provider p ON max_charge.provider_no = p.provider_no"
        ],
