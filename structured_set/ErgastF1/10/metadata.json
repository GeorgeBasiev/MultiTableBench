  "plan": {
    "question_intent": "What is the average number of races per circuit for circuits that have hosted at least 10 races, considering only races where the winning driver achieved a qualifying time in the top 10?",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT circuits.name AS circuit_name, COUNT(DISTINCT races.raceid) AS race_count FROM circuits JOIN races ON circuits.circuitid = races.circuitid JOIN results ON races.raceid = results.raceid JOIN qualifying ON results.driverid = qualifying.driverid AND results.raceid = qualifying.raceid WHERE results.position = 1 AND qualifying.position <= 10 GROUP BY circuits.circuitid HAVING COUNT(DISTINCT races.raceid) >= 10",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT circuits.name AS circuit_name, circuits.circuitid, COUNT(DISTINCT races.raceid) AS race_count",
        "from_clause": "FROM circuits",
        "join_clauses": [
          "JOIN races ON circuits.circuitid = races.circuitid",
          "JOIN results ON races.raceid = results.raceid",
          "JOIN qualifying ON results.driverid = qualifying.driverid AND results.raceid = qualifying.raceid"
        ],
        "where_clauses": [
          "results.position = 1",
          "qualifying.position <= 10"
        ],
        "group_by_clause": "GROUP BY circuits.circuitid",
        "having_clauses": [
          "COUNT(DISTINCT races.raceid) >= 10"
        ],
        "notes": "Counts the number of races per circuit where the winning driver had a qualifying time in the top 10"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(race_count) AS average_races_per_circuit",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Calculates the average number of races per circuit that have hosted at least 10 races"
      }
    ]
  },
