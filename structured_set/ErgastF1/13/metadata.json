  "plan": {
    "question_intent": "What is the nationality of the constructor that won the most races in the year 2005?",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT c.name AS constructor_name, COUNT(r.raceid) AS race_wins, c.nationality FROM constructors c JOIN results rs ON c.constructorid = rs.constructorid JOIN races r ON rs.raceid = r.raceid WHERE rs.positionorder = 1 AND r.year = 2005 GROUP BY c.constructorid, c.name, c.nationality ORDER BY race_wins DESC LIMIT 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.name AS constructor_name, COUNT(r.raceid) AS race_wins, c.nationality",
        "from_clause": "FROM constructors c",
        "join_clauses": [
          "JOIN results rs ON c.constructorid = rs.constructorid",
          "JOIN races r ON rs.raceid = r.raceid"
        ],
        "where_clauses": [
          "rs.positionorder = 1",
          "r.year = 2005"
        ],
        "group_by_clause": "GROUP BY c.constructorid, c.name, c.nationality",
