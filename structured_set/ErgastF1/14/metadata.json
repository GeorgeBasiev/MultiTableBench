  "plan": {
    "question_intent": "average points earned by drivers from British constructors in races held in the United Kingdom",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT d.forename, d.surname, c.name AS constructor_name, r.year, r.name AS race_name, r.date, rs.points FROM drivers d JOIN results rs ON d.driverid = rs.driverid JOIN constructors c ON rs.constructorid = c.constructorid JOIN races r ON rs.raceid = r.raceid JOIN circuits ci ON r.circuitid = ci.circuitid WHERE c.nationality = 'British' AND ci.country = 'United Kingdom' GROUP BY d.forename, d.surname, c.name, r.year, r.name, r.date, rs.points",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT d.driverid, rs.points",
        "from_clause": "FROM drivers d",
        "join_clauses": [
          "JOIN results rs ON d.driverid = rs.driverid",
          "JOIN constructors c ON rs.constructorid = c.constructorid",
          "JOIN races r ON rs.raceid = r.raceid"
        ],
        "where_clauses": [
          "c.nationality = 'British'"
        ],
        "group_by_clause": "GROUP BY d.driverid, rs.points",
        "having_clauses": [],
        "notes": "points earned by British drivers"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.points) AS average_points",
        "from_clause": "FROM (SELECT d.driverid, rs.points FROM drivers d JOIN results rs ON d.driverid = rs.driverid JOIN constructors c ON rs.constructorid = c.constructorid JOIN races r ON rs.raceid = r.raceid WHERE c.nationality = 'British' GROUP BY d.driverid, rs.points) AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "average points earned by British drivers"
      }
    ]
  },
