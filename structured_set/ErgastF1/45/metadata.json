  "plan": {
    "question_intent": "average points per race for constructors that scored at least 100 points in the 2005 season",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT constructors.constructorid, constructors.name, races.year, AVG(constructorresults.points) AS avg_points FROM constructors JOIN constructorresults ON constructors.constructorid = constructorresults.constructorid JOIN races ON constructorresults.raceid = races.raceid WHERE (races.year = 2005) AND (constructors.constructorid IN (SELECT constructorid FROM constructorresults JOIN races ON constructorresults.raceid = races.raceid WHERE races.year = 2005 GROUP BY constructorid HAVING SUM(points) >= 100)) GROUP BY constructors.constructorid, constructors.name, races.year HAVING AVG(constructorresults.points) > 0",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT constructors.constructorid, constructors.name, races.year, AVG(constructorresults.points) AS avg_points",
        "from_clause": "FROM constructors",
        "join_clauses": [
          "JOIN constructorresults ON constructors.constructorid = constructorresults.constructorid",
          "JOIN races ON constructorresults.raceid = races.raceid"
        ],
        "where_clauses": [
          "races.year = 2005",
          "constructors.constructorid IN (SELECT constructorid FROM constructorresults JOIN races ON constructorresults.raceid = races.raceid WHERE races.year = 2005 GROUP BY constructorid HAVING SUM(points) >= 100)"
        ],
        "group_by_clause": "GROUP BY constructors.constructorid, constructors.name, races.year",
        "having_clauses": [
          "AVG(constructorresults.points) > 0"
        ],
        "notes": "returns constructorid, name, year, and average points for constructors that scored at least 100 points in the 2005 season"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.avg_points) AS average_points",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "calculates the average points per race for the filtered constructors"
      }
    ]
