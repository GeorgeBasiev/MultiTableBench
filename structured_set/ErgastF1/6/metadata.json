  "plan": {
    "question_intent": "average points scored by drivers from the United Kingdom in races held in the United Kingdom",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT d.driverid, d.forename, d.surname, r.raceid, r.name, res.points FROM drivers AS d JOIN results AS res ON d.driverid = res.driverid JOIN races AS r ON res.raceid = r.raceid JOIN circuits AS c ON r.circuitid = c.circuitid WHERE d.nationality = 'British' AND c.country = 'UK' GROUP BY d.driverid, d.forename, d.surname, r.raceid, r.name, res.points",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT d.driverid, d.forename, d.surname, r.raceid, r.name, res.points",
        "from_clause": "FROM drivers AS d",
        "join_clauses": [
          "JOIN results AS res ON d.driverid = res.driverid",
          "JOIN races AS r ON res.raceid = r.raceid",
          "JOIN circuits AS c ON r.circuitid = c.circuitid"
        ],
        "where_clauses": [
          "d.nationality = 'British'",
          "c.country = 'UK'"
        ],
        "group_by_clause": "GROUP BY d.driverid, d.forename, d.surname, r.raceid, r.name, res.points",
        "having_clauses": [],
        "notes": "returns driver details, race details, and points scored by British drivers in UK races"
      },
