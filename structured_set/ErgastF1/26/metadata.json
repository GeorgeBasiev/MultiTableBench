  "plan": {
    "question_intent": "average points per race for constructors from the UK",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT r.year, c.name AS constructor_name, r.name AS race_name, AVG(cr.points) AS avg_points FROM races r JOIN constructorresults cr ON r.raceid = cr.raceid JOIN constructors c ON cr.constructorid = c.constructorid JOIN circuits ci ON r.circuitid = ci.circuitid WHERE c.nationality = 'British' GROUP BY r.year, c.name, r.name",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT r.year, c.name AS constructor_name, AVG(cr.points) AS avg_points",
        "from_clause": "FROM races r",
        "join_clauses": [
          "JOIN constructorresults cr ON r.raceid = cr.raceid",
          "JOIN constructors c ON cr.constructorid = c.constructorid"
        ],
        "where_clauses": [
          "c.nationality = 'British'"
        ],
        "group_by_clause": "GROUP BY r.year, c.name",
        "having_clauses": [],
        "notes": "average points per race for constructors from the UK"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.avg_points) AS average_points",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "final scalar block"
      }
    ]
  },
