  "plan": {
    "question_intent": "Total points scored by British drivers in races held in European countries during the 2006 season",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT d.forename || ' ' || d.surname AS driver_name, r.year AS race_year, c.country AS race_country, cr.points FROM drivers d JOIN results r ON d.driverid = r.driverid JOIN constructorresults cr ON r.constructorid = cr.constructorid JOIN races ra ON r.raceid = ra.raceid JOIN circuits c ON ra.circuitid = c.circuitid WHERE (d.nationality = 'British') AND (c.country IN ('Germany', 'Austria', 'Switzerland', 'Liechtenstein', 'Belgium', 'Netherlands', 'Luxembourg', 'France', 'Monaco', 'Italy', 'San Marino', 'Vatican City', 'Spain', 'Portugal', 'Andorra', 'Gibraltar', 'Malta', 'Cyprus', 'Greece', 'Turkey', 'Armenia', 'Azerbaijan', 'Georgia', 'Russia', 'Ukraine', 'Belarus', 'Moldova', 'Romania', 'Bulgaria', 'Hungary', 'Slovakia', 'Czech Republic', 'Poland', 'Lithuania', 'Latvia', 'Estonia', 'Kosovo', 'Albania', 'Montenegro', 'North Macedonia', 'Serbia', 'Croatia', 'Slovenia', 'Bosnia and Herzegovina')) AND (r.year = 2006)",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT cr.points",
        "from_clause": "FROM constructorresults cr",
        "join_clauses": [
          "JOIN results r ON cr.raceid = r.raceid AND cr.constructorid = r.constructorid",
          "JOIN drivers d ON r.driverid = d.driverid"
        ],
        "where_clauses": [
          "d.nationality = 'British'",
          "r.year = 2006"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Points scored by British drivers in the 2006 season"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(leaf_1.points) AS total_points",
