  "plan": {
    "question_intent": "Average number of pitstops per driver in races where the driver achieved their fastest lap",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT d.forename, d.surname, r.raceid, r.year, r.name AS race_name, p.stop AS pitstops FROM drivers AS d JOIN results AS r ON d.driverid = r.driverid JOIN races AS ra ON r.raceid = ra.raceid JOIN pitstops AS p ON r.raceid = p.raceid AND r.driverid = p.driverid WHERE r.fastestlap = 1 GROUP BY d.forename, d.surname, r.raceid, r.year, r.name, p.stop",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT d.driverid, r.raceid, COUNT(p.stop) AS pitstops",
        "from_clause": "FROM drivers AS d",
        "join_clauses": [
          "JOIN results AS r ON d.driverid = r.driverid",
          "JOIN pitstops AS p ON r.raceid = p.raceid AND r.driverid = p.driverid"
        ],
        "where_clauses": [
          "r.fastestlap = 1"
        ],
        "group_by_clause": "GROUP BY d.driverid, r.raceid",
        "having_clauses": [],
        "notes": "Counts the number of pitstops for each driver in races where they achieved their fastest lap"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.pitstops)",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Calculates the average number of pitstops per driver in races where the driver achieved their fastest lap"
      }
    ]
  },
