  "plan": {
    "question_intent": "name of the constructor with the most wins in the 2008 season",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT constructor.name AS constructor_name, COUNT(target.win) AS win_count FROM constructors AS constructor JOIN results AS result ON constructor.constructorid = result.constructorid JOIN races AS race ON result.raceid = race.raceid JOIN target AS target ON result.driverid = target.driverid AND result.raceid = target.raceid WHERE race.year = 2008 AND target.win = 1 GROUP BY constructor.name ORDER BY win_count DESC LIMIT 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT constructor.name AS constructor_name, COUNT(target.win) AS win_count",
        "from_clause": "FROM constructors AS constructor",
        "join_clauses": [
          "JOIN results AS result ON constructor.constructorid = result.constructorid",
          "JOIN races AS race ON result.raceid = race.raceid",
          "JOIN target AS target ON result.driverid = target.driverid AND result.raceid = target.raceid"
        ],
        "where_clauses": [
          "race.year = 2008",
          "target.win = 1"
        ],
        "group_by_clause": "GROUP BY constructor.name",
        "having_clauses": [],
        "notes": "counts wins by constructor in the 2008 season"
      },
