  "plan": {
    "question_intent": "Average time per lap for the fastest lap in races where a specific driver achieved a win",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT r.raceid, r.name AS race_name, r.date, d.driverid, d.forename, d.surname, lt.lap, lt.position, lt.time, lt.milliseconds FROM races r JOIN results rs ON r.raceid = rs.raceid JOIN drivers d ON rs.driverid = d.driverid JOIN laptimes lt ON rs.raceid = lt.raceid AND rs.driverid = lt.driverid WHERE rs.position = 1 AND d.driverid = 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT r.raceid, d.driverid, lt.milliseconds",
        "from_clause": "FROM races r",
        "join_clauses": [
          "JOIN results rs ON r.raceid = rs.raceid",
          "JOIN drivers d ON rs.driverid = d.driverid",
          "JOIN laptimes lt ON rs.raceid = lt.raceid AND rs.driverid = lt.driverid"
        ],
        "where_clauses": [
          "rs.position = 1",
          "d.driverid = 1"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Retrieves the race ID, driver ID, and lap time in milliseconds for the fastest lap in races where the driver with ID 1 achieved a win"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.milliseconds) AS average_time_per_lap",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Calculates the average time per lap for the fastest lap in races where the driver with ID 1 achieved a win"
      }
    ]
  },
