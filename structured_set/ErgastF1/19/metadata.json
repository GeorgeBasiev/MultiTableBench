  "plan": {
    "question_intent": "average points per race for drivers from Australia",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT d.driverid, d.forename, d.surname, r.raceid, r.name AS race_name, r.year, cs.points FROM drivers d JOIN results r ON d.driverid = r.driverid JOIN constructorstandings cs ON r.constructorid = cs.constructorid WHERE d.nationality = 'Australian' ORDER BY cs.points DESC",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT d.driverid, r.raceid, cs.points",
        "from_clause": "FROM drivers d",
        "join_clauses": [
          "JOIN results r ON d.driverid = r.driverid",
          "JOIN constructorstandings cs ON r.constructorid = cs.constructorid"
        ],
        "where_clauses": [
          "d.nationality = 'Australian'"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "points earned by Australian drivers in each race"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(points) AS average_points",
