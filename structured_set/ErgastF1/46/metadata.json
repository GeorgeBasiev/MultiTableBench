  "plan": {
    "question_intent": "What is the nationality of the constructor who achieved the highest average points per race in the 2020 season?",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT c.nationality AS constructor_nationality, AVG(cr.points) AS avg_points_per_race FROM constructors AS c JOIN constructorresults AS cr ON c.constructorid = cr.constructorid JOIN races AS r ON cr.raceid = r.raceid WHERE r.year = 2020 GROUP BY c.constructorid ORDER BY avg_points_per_race DESC LIMIT 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.constructorid, c.nationality, AVG(cr.points) AS avg_points_per_race",
        "from_clause": "FROM constructors AS c",
        "join_clauses": [
          "JOIN constructorresults AS cr ON c.constructorid = cr.constructorid",
          "JOIN races AS r ON cr.raceid = r.raceid"
        ],
        "where_clauses": [
          "r.year = 2020"
        ],
        "group_by_clause": "GROUP BY c.constructorid",
        "having_clauses": [],
        "notes": "Calculates the average points per race for each constructor in the 2020 season"
      },
      {
        "name": "leaf_2",
        "role": "leaf",
        "select_clause": "SELECT MAX(avg_points_per_race) AS max_avg_points",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Finds the maximum average points per race among all constructors"
      },
      {
        "name": "leaf_3",
        "role": "leaf",
        "select_clause": "SELECT constructorid, nationality",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [
          "avg_points_per_race = (SELECT max_avg_points FROM {{leaf_2}})"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Retrieves the constructor details for the constructor with the highest average points per race"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT nationality",
        "from_clause": "FROM {{leaf_3}} AS leaf_3",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Final scalar block returning the nationality of the constructor with the highest average points per race in the 2020 season"
      }
    ]
  },
