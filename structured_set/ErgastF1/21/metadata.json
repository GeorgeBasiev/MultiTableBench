  "plan": {
    "question_intent": "Calculate the average points scored by British constructors in races held in Australia",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.constructor_name, leaf_1.race_name, leaf_1.points FROM (SELECT constructors.name AS constructor_name, races.name AS race_name, constructorresults.points AS points FROM constructors JOIN constructorresults ON constructors.constructorid = constructorresults.constructorid JOIN races ON constructorresults.raceid = races.raceid JOIN circuits ON races.circuitid = circuits.circuitid WHERE constructors.nationality = 'British' AND circuits.country = 'Australia') AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT constructors.name AS constructor_name, races.name AS race_name, constructorresults.points AS points",
        "from_clause": "FROM constructors",
        "join_clauses": [
          "JOIN constructorresults ON constructors.constructorid = constructorresults.constructorid",
          "JOIN races ON constructorresults.raceid = races.raceid"
        ],
        "where_clauses": [
          "constructors.nationality = 'British'",
          "circuits.country = 'Australia'"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Returns the name of British constructors, the name of races held in Australia, and the points they scored in those races"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.points) AS average_points",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Calculates the average points scored by British constructors in races held in Australia"
      }
    ]
  },
