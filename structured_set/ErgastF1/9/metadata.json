  "plan": {
    "question_intent": "Calculate the average number of pit stops per race for drivers from the British nationality who have achieved at least one win",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT d.driverid, d.forename, d.surname, r.raceid, r.name AS race_name, COUNT(p.stop) AS pit_stops FROM drivers d JOIN results r ON d.driverid = r.driverid JOIN pitstops p ON d.driverid = p.driverid AND r.raceid = p.raceid JOIN target t ON d.driverid = t.driverid AND r.raceid = t.raceid WHERE d.nationality = 'British' AND t.win = 1 GROUP BY d.driverid, d.forename, d.surname, r.raceid, r.name",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT d.driverid, r.raceid, COUNT(p.stop) AS pit_stops",
        "from_clause": "FROM drivers d",
        "join_clauses": [
          "JOIN results r ON d.driverid = r.driverid",
          "JOIN pitstops p ON d.driverid = p.driverid AND r.raceid = p.raceid",
          "JOIN target t ON d.driverid = t.driverid AND r.raceid = t.raceid"
        ],
        "where_clauses": [
          "d.nationality = 'British'",
          "t.win = 1"
        ],
        "group_by_clause": "GROUP BY d.driverid, r.raceid",
        "having_clauses": [],
        "notes": "Counts the number of pit stops for each British driver who has achieved at least one win, per race"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.pit_stops)",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Calculates the average number of pit stops per race for British drivers who have achieved at least one win"
      }
    ]
  },
