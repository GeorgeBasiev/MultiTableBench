  "plan": {
    "question_intent": "Total points scored by British constructors in races held in Australia",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT cr.raceid, r.year, r.round, r.name AS race_name, c.name AS constructor_name, conr.points FROM constructorresults AS cr JOIN races AS r ON cr.raceid = r.raceid JOIN circuits AS c ON r.circuitid = c.circuitid JOIN constructors AS cons ON cr.constructorid = cons.constructorid WHERE cons.nationality = 'British' AND c.country = 'Australia' ORDER BY cr.raceid, cons.name",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT cr.raceid, r.year, r.round, r.name AS race_name, c.name AS constructor_name, cr.points",
        "from_clause": "FROM constructorresults AS cr",
        "join_clauses": [
          "JOIN races AS r ON cr.raceid = r.raceid",
          "JOIN circuits AS c ON r.circuitid = c.circuitid",
          "JOIN constructors AS cons ON cr.constructorid = cons.constructorid"
        ],
        "where_clauses": [
          "cons.nationality = 'British'",
          "c.country = 'Australia'"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Points scored by British constructors in races held in Australia"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT SUM(leaf_1.points) AS total_points",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
