  "plan": {
    "question_intent": "Find the nationality of the driver who won the first race of the year 2009",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.nationality FROM (SELECT d.nationality FROM races r JOIN results res ON r.raceid = res.raceid JOIN drivers d ON res.driverid = d.driverid WHERE (r.year = 2009) AND (r.round = 1) AND (res.position = 1)) AS leaf_1",
