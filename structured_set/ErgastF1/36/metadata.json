  "plan": {
    "question_intent": "What is the nationality of the driver who achieved the fastest lap time in the 2007 Australian Grand Prix?",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT r.raceid, r.name AS race_name, d.driverid, d.forename, d.surname, d.nationality, res.fastestlaptime FROM races r JOIN results res ON r.raceid = res.raceid JOIN drivers d ON res.driverid = d.driverid WHERE r.year = 2007 AND r.round = 1 AND res.fastestlaptime IS NOT NULL ORDER BY res.fastestlaptime ASC LIMIT 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT d.nationality",
        "from_clause": "FROM races r",
        "join_clauses": [
          "JOIN results res ON r.raceid = res.raceid",
          "JOIN drivers d ON res.driverid = d.driverid"
        ],
        "where_clauses": [
          "r.year = 2007",
          "r.round = 1",
          "res.fastestlaptime IS NOT NULL"
        ],
