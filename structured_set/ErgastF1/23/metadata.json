  "plan": {
    "question_intent": "Identify the nationality of the constructor that won the most races in the 2005 season",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT race.year, race.name, constructor.name AS constructor_name, constructor.nationality, COUNT(results.resultid) AS race_wins FROM races AS race JOIN results ON race.raceid = results.raceid JOIN constructors AS constructor ON results.constructorid = constructor.constructorid WHERE race.year = 2005 AND results.position = 1 GROUP BY race.raceid, constructor.constructorid ORDER BY race_wins DESC LIMIT 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT race.year, constructor.constructorid, COUNT(results.resultid) AS race_wins",
        "from_clause": "FROM races AS race",
        "join_clauses": [
          "JOIN results ON race.raceid = results.raceid",
          "JOIN constructors AS constructor ON results.constructorid = constructor.constructorid"
        ],
        "where_clauses": [
          "race.year = 2005",
          "results.position = 1"
        ],
        "group_by_clause": "GROUP BY race.year, constructor.constructorid",
        "having_clauses": [],
        "notes": "Counts the number of race wins per constructor in the 2005 season"
      },
      {
        "name": "leaf_2",
        "role": "leaf",
        "select_clause": "SELECT constructor.constructorid, constructor.nationality",
        "from_clause": "FROM constructors AS constructor",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Retrieves the nationality of each constructor"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT leaf_1.nationality",
        "from_clause": "FROM (SELECT leaf_1.year, leaf_1.constructorid, leaf_1.race_wins, leaf_2.nationality FROM {{leaf_1}} AS leaf_1 JOIN {{leaf_2}} AS leaf_2 ON leaf_1.constructorid = leaf_2.constructorid) AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Final scalar block that retrieves the nationality of the constructor with the most race wins in the 2005 season"
      }
    ]
  },
