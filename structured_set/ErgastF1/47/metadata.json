  "plan": {
    "question_intent": "What was the nationality of the constructor that scored the highest average points per race in the 2004 season?",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT constructors.name, AVG(constructorresults.points) AS avg_points, races.year FROM constructors JOIN constructorresults ON constructors.constructorid = constructorresults.constructorid JOIN races ON constructorresults.raceid = races.raceid WHERE races.year = 2004 GROUP BY constructors.constructorid, races.year ORDER BY avg_points DESC LIMIT 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT constructors.constructorid, constructors.nationality, AVG(constructorresults.points) AS avg_points",
        "from_clause": "FROM constructors",
        "join_clauses": [
          "JOIN constructorresults ON constructors.constructorid = constructorresults.constructorid",
          "JOIN races ON constructorresults.raceid = races.raceid"
        ],
        "where_clauses": [
          "races.year = 2004"
        ],
        "group_by_clause": "GROUP BY constructors.constructorid",
        "having_clauses": [],
        "notes": "Calculates the average points per race for each constructor in the 2004 season"
      },
