  "plan": {
    "question_intent": "average points scored by drivers in races where they finished in the top 10",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT d.driverid, d.forename, d.surname, r.raceid, ra.name AS race_name, r.points\nFROM drivers AS d\nJOIN results AS r ON d.driverid = r.driverid\nJOIN races AS ra ON r.raceid = ra.raceid\nWHERE r.position <= 10 AND r.position IS NOT NULL",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT d.driverid, d.forename, d.surname, r.raceid, ra.name AS race_name, r.points",
