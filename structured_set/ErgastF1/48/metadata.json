  "plan": {
    "question_intent": "Average points per race for constructors that have won at least one race in the 2005 season",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.name AS constructor_name, r.year AS race_year, cr.points FROM constructors c JOIN constructorresults cr ON c.constructorid = cr.constructorid JOIN races r ON cr.raceid = r.raceid JOIN (SELECT constructorid FROM constructorstandings WHERE wins > 0 AND raceid IN (SELECT raceid FROM races WHERE year = 2005)) AS winning_constructors ON c.constructorid = winning_constructors.constructorid GROUP BY c.constructorid, r.raceid",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.constructorid, AVG(cr.points) AS avg_points",
        "from_clause": "FROM constructors c",
        "join_clauses": [
          "JOIN constructorresults cr ON c.constructorid = cr.constructorid",
          "JOIN races r ON cr.raceid = r.raceid"
        ],
        "where_clauses": [
          "c.constructorid IN (SELECT constructorid FROM constructorstandings WHERE wins > 0 AND raceid IN (SELECT raceid FROM races WHERE year = 2005))"
        ],
        "group_by_clause": "GROUP BY c.constructorid",
        "having_clauses": [],
        "notes": "Average points per constructor for constructors that won at least one race in 2005"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.avg_points) AS average_points",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Final scalar block for average points per race for constructors that won at least one race in 2005"
      }
    ]
  },
