  "plan": {
    "question_intent": "Calculate the average points per constructor from races held in Australia",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.name AS constructor_name, AVG(cr.points) AS average_points FROM constructorresults cr JOIN constructors c ON cr.constructorid = c.constructorid JOIN races r ON cr.raceid = r.raceid JOIN circuits ci ON r.circuitid = ci.circuitid WHERE ci.country = 'Australia' GROUP BY c.name",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.name AS constructor_name, cr.points",
        "from_clause": "FROM constructorresults cr",
        "join_clauses": [
          "JOIN constructors c ON cr.constructorid = c.constructorid",
          "JOIN races r ON cr.raceid = r.raceid",
          "JOIN circuits ci ON r.circuitid = ci.circuitid"
        ],
        "where_clauses": [
          "ci.country = 'Australia'"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Retrieves constructor names and their points from races held in Australia"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.points) AS average_points_per_constructor",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Calculates the average points per constructor from the filtered data"
      }
    ]
  },
