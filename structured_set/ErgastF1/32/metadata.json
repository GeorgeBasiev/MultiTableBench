  "plan": {
    "question_intent": "average points per driver for races on circuits in Australia",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT d.forename, d.surname, c.country, r.name AS race_name, r.date, res.points FROM results AS res JOIN drivers AS d ON res.driverid = d.driverid JOIN races AS r ON res.raceid = r.raceid JOIN circuits AS c ON r.circuitid = c.circuitid WHERE (c.country = 'Australia')",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT d.driverid, r.raceid, res.points",
        "from_clause": "FROM results AS res",
        "join_clauses": [
          "JOIN drivers AS d ON res.driverid = d.driverid",
          "JOIN races AS r ON res.raceid = r.raceid",
          "JOIN circuits AS c ON r.circuitid = c.circuitid"
        ],
        "where_clauses": [
          "(c.country = 'Australia')"
        ],
        "group_by_clause": "GROUP BY d.driverid, r.raceid, res.points",
        "having_clauses": [],
        "notes": "points per driver per race for races on circuits in Australia"
      },
