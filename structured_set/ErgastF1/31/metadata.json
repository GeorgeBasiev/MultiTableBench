  "plan": {
    "question_intent": "Calculate the average points per race for constructors who have raced in circuits located in Australia, Germany, United Kingdom, or USA",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.constructorid, c.name, r.raceid, r.name AS race_name, cr.points FROM constructors AS c JOIN constructorresults AS cr ON c.constructorid = cr.constructorid JOIN races AS r ON cr.raceid = r.raceid JOIN circuits AS ci ON r.circuitid = ci.circuitid WHERE (ci.country IN ('Australia', 'Germany', 'United Kingdom', 'USA'))",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.constructorid, c.name, r.raceid, r.name AS race_name, cr.points",
        "from_clause": "FROM constructors AS c",
        "join_clauses": [
          "JOIN constructorresults AS cr ON c.constructorid = cr.constructorid",
          "JOIN races AS r ON cr.raceid = r.raceid",
          "JOIN circuits AS ci ON r.circuitid = ci.circuitid"
        ],
        "where_clauses": [
          "ci.country IN ('Australia', 'Germany', 'United Kingdom', 'USA')"
        ],
        "group_by_clause": "",
