  "plan": {
    "question_intent": "average points per race for drivers from Germany who have achieved a position in the top 5 in at least one race",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT d.driverid, d.forename, d.surname, r.raceid, r.year, r.name AS race_name, rs.points, rs.position FROM drivers d JOIN results r ON d.driverid = r.driverid JOIN races r ON r.raceid = rs.raceid WHERE d.nationality = 'German' AND rs.position <= 5",
