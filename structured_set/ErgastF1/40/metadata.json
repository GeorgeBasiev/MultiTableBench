  "plan": {
    "question_intent": "What is the average points per race for constructors who have won at least one race in Australia?",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.name AS constructor_name, r.year AS race_year, cr.points FROM constructors AS c JOIN constructorresults AS cr ON c.constructorid = cr.constructorid JOIN races AS r ON cr.raceid = r.raceid JOIN circuits AS ci ON r.circuitid = ci.circuitid WHERE ci.country = 'Australia' AND cr.points > 0",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.constructorid, c.name, AVG(cr.points) AS avg_points",
        "from_clause": "FROM constructors AS c",
        "join_clauses": [
          "JOIN constructorresults AS cr ON c.constructorid = cr.constructorid",
          "JOIN races AS r ON cr.raceid = r.raceid",
          "JOIN circuits AS ci ON r.circuitid = ci.circuitid",
          "JOIN target AS t ON c.constructorid = t.driverid"
        ],
        "where_clauses": [
          "ci.country = 'Australia'",
          "t.win = 1"
        ],
        "group_by_clause": "GROUP BY c.constructorid, c.name",
        "having_clauses": [
          "AVG(cr.points) > 0"
        ],
        "notes": "Average points per race for constructors who have won at least one race in Australia"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.avg_points) AS average_points_per_race",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Final scalar block calculating the average points per race for constructors who have won at least one race in Australia"
      }
    ]
