  "plan": {
    "question_intent": "average number of pit stops per race for drivers from European countries",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.driverid, leaf_1.forename, leaf_1.surname, leaf_1.raceid, leaf_1.pit_stop_count FROM (SELECT d.driverid, d.forename, d.surname, r.raceid, COUNT(p.stop) AS pit_stop_count FROM drivers AS d JOIN results AS r ON d.driverid = r.driverid JOIN pitstops AS p ON r.driverid = p.driverid AND r.raceid = p.raceid WHERE d.nationality IN ('British', 'French', 'German', 'Italian', 'Spanish', 'Belgian', 'Swedish', 'Dutch', 'Austrian', 'Finnish') GROUP BY d.driverid, d.forename, d.surname, r.raceid) AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT d.driverid, d.forename, d.surname, r.raceid, COUNT(p.stop) AS pit_stop_count",
        "from_clause": "FROM drivers AS d",
        "join_clauses": [
          "JOIN results AS r ON d.driverid = r.driverid",
          "JOIN pitstops AS p ON r.driverid = p.driverid AND r.raceid = p.raceid"
        ],
        "where_clauses": [
          "d.nationality IN ('British', 'French', 'German', 'Italian', 'Spanish', 'Belgian', 'Swedish', 'Dutch', 'Austrian', 'Finnish')"
        ],
        "group_by_clause": "GROUP BY d.driverid, d.forename, d.surname, r.raceid",
        "having_clauses": [],
        "notes": "counts pit stops for each driver-race combination from European countries"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.pit_stop_count)",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "calculates the average number of pit stops per race for drivers from European countries"
      }
    ]
  },
