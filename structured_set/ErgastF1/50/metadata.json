  "plan": {
    "question_intent": "Identify the nationality of the constructor who achieved the highest cumulative points in the 2008 season",
    "answer_mode": "text",
    "final_block_name": "root",
    "detail_query": "SELECT c.name, c.nationality, SUM(cr.points) AS total_points FROM constructors c JOIN constructorresults cr ON c.constructorid = cr.constructorid JOIN races r ON cr.raceid = r.raceid WHERE r.year = 2008 GROUP BY c.constructorid, c.name, c.nationality ORDER BY total_points DESC LIMIT 1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.constructorid, c.name, c.nationality, SUM(cr.points) AS total_points",
        "from_clause": "FROM constructors c",
        "join_clauses": [
          "JOIN constructorresults cr ON c.constructorid = cr.constructorid",
          "JOIN races r ON cr.raceid = r.raceid"
        ],
        "where_clauses": [
          "r.year = 2008"
        ],
        "group_by_clause": "GROUP BY c.constructorid, c.name, c.nationality",
        "having_clauses": [],
        "notes": "Calculates the total points for each constructor in the 2008 season"
      },
      {
        "name": "leaf_2",
        "role": "leaf",
        "select_clause": "SELECT MAX(total_points) AS max_points",
        "from_clause": "FROM ({{leaf_1}}) AS constructor_points",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Finds the maximum points achieved by any constructor in the 2008 season"
      },
      {
        "name": "leaf_3",
        "role": "leaf",
        "select_clause": "SELECT constructorid, name, nationality",
        "from_clause": "FROM ({{leaf_1}}) AS constructor_points",
        "join_clauses": [],
        "where_clauses": [
          "total_points = ({{leaf_2}})"
        ],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Identifies the constructor(s) who achieved the maximum points in the 2008 season"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT nationality",
        "from_clause": "FROM ({{leaf_3}}) AS top_constructor",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Returns the nationality of the constructor with the highest cumulative points in the 2008 season"
      }
    ]
