  "plan": {
    "question_intent": "Average number of pit stops per race for drivers from British constructors",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT r.raceid, r.year, r.round, r.name AS race_name, d.driverid, d.forename, d.surname, c.name AS constructor_name, ps.stop AS pit_stop_number, ps.lap, ps.time, ps.duration FROM pitstops ps JOIN results r ON ps.raceid = r.raceid AND ps.driverid = r.driverid JOIN drivers d ON r.driverid = d.driverid JOIN constructors c ON r.constructorid = c.constructorid WHERE c.nationality = 'British' GROUP BY ps.raceid, ps.driverid, ps.stop",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT r.raceid, d.driverid, COUNT(ps.stop) AS pit_stop_count",
        "from_clause": "FROM pitstops ps",
        "join_clauses": [
          "JOIN results r ON ps.raceid = r.raceid AND ps.driverid = r.driverid",
          "JOIN drivers d ON r.driverid = d.driverid",
          "JOIN constructors c ON r.constructorid = c.constructorid"
        ],
        "where_clauses": [
          "c.nationality = 'British'"
        ],
        "group_by_clause": "GROUP BY r.raceid, d.driverid",
        "having_clauses": [],
        "notes": "Counts the number of pit stops for each driver from British constructors in each race"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.pit_stop_count)",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "Calculates the average number of pit stops per race for drivers from British constructors"
      }
    ]
  },
