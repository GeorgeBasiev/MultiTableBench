  "plan": {
    "question_intent": "average points per race for drivers from British nationality who have achieved a win in at least one race",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT ds.driverid, d.nationality, ds.points, ds.raceid FROM driverstandings AS ds JOIN drivers AS d ON ds.driverid = d.driverid JOIN races AS r ON ds.raceid = r.raceid WHERE d.nationality = 'British' AND EXISTS (SELECT 1 FROM driverstandings AS ds2 JOIN target AS t ON ds2.driverid = t.driverid WHERE ds2.driverid = ds.driverid AND t.win = 1)",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT ds.driverid, SUM(ds.points) AS total_points, COUNT(DISTINCT ds.raceid) AS race_count",
        "from_clause": "FROM driverstandings AS ds",
        "join_clauses": [
          "JOIN drivers AS d ON ds.driverid = d.driverid",
          "JOIN races AS r ON ds.raceid = r.raceid"
        ],
        "where_clauses": [
          "d.nationality = 'British'",
          "EXISTS (SELECT 1 FROM driverstandings AS ds2 JOIN target AS t ON ds2.driverid = t.driverid WHERE ds2.driverid = ds.driverid AND t.win = 1)"
        ],
        "group_by_clause": "GROUP BY ds.driverid",
        "having_clauses": [],
        "notes": "sums points and counts distinct races for British drivers who have achieved at least one win"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.total_points / leaf_1.race_count) AS avg_points_per_race",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "calculates the average points per race for British drivers who have achieved at least one win"
      }
    ]
  },
