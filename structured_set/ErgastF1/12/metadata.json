  "plan": {
    "question_intent": "Average points per race for constructors who have won at least one race in the year 2009",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT c.name AS constructor_name, r.year, AVG(cs.points) AS avg_points FROM constructors AS c JOIN constructorstandings AS cs ON c.constructorid = cs.constructorid JOIN races AS r ON cs.raceid = r.raceid WHERE r.year = 2009 AND c.constructorid IN (SELECT DISTINCT cs2.constructorid FROM constructorstandings AS cs2 JOIN races AS r2 ON cs2.raceid = r2.raceid WHERE r2.year = 2009 AND cs2.wins > 0) GROUP BY c.name, r.year",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT c.constructorid, c.name, r.year, AVG(cs.points) AS avg_points",
        "from_clause": "FROM constructors AS c",
        "join_clauses": [
          "JOIN constructorstandings AS cs ON c.constructorid = cs.constructorid",
          "JOIN races AS r ON cs.raceid = r.raceid"
        ],
        "where_clauses": [
          "r.year = 2009",
          "c.constructorid IN (SELECT DISTINCT cs2.constructorid FROM constructorstandings AS cs2 JOIN races AS r2 ON cs2.raceid = r2.raceid WHERE r2.year = 2009 AND cs2.wins > 0)"
        ],
        "group_by_clause": "GROUP BY c.constructorid, c.name, r.year",
        "having_clauses": [],
        "notes": "Average points per race for constructors who have won at least one race in the year 2009"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.avg_points)",
