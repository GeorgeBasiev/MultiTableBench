  "plan": {
    "question_intent": "average number of pit stops per driver in races where the driver achieved a position of 10 or better",
    "answer_mode": "aggregate",
    "final_block_name": "root",
    "detail_query": "SELECT leaf_1.driver_name, leaf_1.stop_count FROM (SELECT d.forename || ' ' || d.surname AS driver_name, COUNT(p.stop) AS stop_count FROM pitstops p JOIN drivers d ON p.driverid = d.driverid JOIN results r ON p.driverid = r.driverid AND p.raceid = r.raceid WHERE r.position <= 10 GROUP BY d.forename, d.surname) AS leaf_1",
    "blocks": [
      {
        "name": "leaf_1",
        "role": "leaf",
        "select_clause": "SELECT d.forename || ' ' || d.surname AS driver_name, COUNT(p.stop) AS stop_count",
        "from_clause": "FROM pitstops p",
        "join_clauses": [
          "JOIN drivers d ON p.driverid = d.driverid",
          "JOIN results r ON p.driverid = r.driverid AND p.raceid = r.raceid"
        ],
        "where_clauses": [
          "r.position <= 10"
        ],
        "group_by_clause": "GROUP BY d.forename, d.surname",
        "having_clauses": [],
        "notes": "counts the number of pit stops for each driver who achieved a position of 10 or better in a race"
      },
      {
        "name": "root",
        "role": "root",
        "select_clause": "SELECT AVG(leaf_1.stop_count) AS average_pit_stops_per_driver",
        "from_clause": "FROM {{leaf_1}} AS leaf_1",
        "join_clauses": [],
        "where_clauses": [],
        "group_by_clause": "",
        "having_clauses": [],
        "notes": "calculates the average number of pit stops per driver from the leaf_1 subquery"
      }
    ]
  },
